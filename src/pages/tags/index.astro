---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import {
  getDateIndex,
  getQualifiedTags,
  getTotalTagCount,
} from '../../lib/blog-data.mjs';
import { encodeTagParam } from '../../lib/tag-path';

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');

const [dateIndex, tagObjects, totalTags] = await Promise.all([
  getDateIndex(),
  getQualifiedTags(),
  getTotalTagCount(),
]);
---

<Layout title="Tags">
  <div class="min-h-full theme-surface">
    <PageHeader dateIndex={dateIndex} />

    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
      <!-- Header -->
      <div class="mb-6 border-b pb-3 theme-border">
        <h1 class="text-2xl font-bold theme-text-primary">
          $ ls tags/
        </h1>
        <p class="text-sm mt-1 theme-text-muted">
          {tagObjects.length} topics ({totalTags - tagObjects.length} single-post tags hidden)
        </p>
      </div>

      <!-- Search filter -->
      <div class="tag-search-wrap">
        <input
          id="tag-filter"
          type="text"
          placeholder="filter tags…"
          autocomplete="off"
          class="tag-filter-input"
        />
        <span id="tag-filter-count" class="tag-filter-count"></span>
      </div>

      {tagObjects.length === 0 ? (
        <div class="py-8">
          <p class="text-sm theme-text-muted">no tags found.</p>
        </div>
      ) : (
        <div id="tag-grid" class="grid grid-cols-2 sm:grid-cols-3 gap-2">
          {tagObjects.map((tag) => (
            <a
              href={`${base}tags/${encodeTagParam(tag.name)}`}
              class="tag-index-card"
              data-tag={tag.name.toLowerCase()}
            >
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium theme-text-primary">#{tag.name}</span>
                <span class="text-xs font-mono theme-text-muted">
                  {tag.count}
                </span>
              </div>
            </a>
          ))}
        </div>
      )}

      <div id="tag-no-results" class="tag-no-results" hidden>
        no matching tags
      </div>
    </div>
  </div>
</Layout>

<script>
  function initTagFilter() {
    const input = document.getElementById('tag-filter') as
      | (HTMLInputElement & { __tagFilterBound?: boolean })
      | null;
    const grid = document.getElementById('tag-grid');
    const countEl = document.getElementById('tag-filter-count');
    const noResults = document.getElementById('tag-no-results');
    if (!input || !grid) return;

    const cards = Array.from(grid.querySelectorAll<HTMLAnchorElement>('.tag-index-card'));
    const total = cards.length;

    function filter() {
      const query = input.value.toLowerCase().trim();
      let visible = 0;

      for (const card of cards) {
        const tag = card.getAttribute('data-tag') || '';
        const match = !query || tag.includes(query);
        card.hidden = !match;
        if (match) visible++;
      }

      if (countEl) {
        countEl.textContent = query ? `${visible} / ${total}` : '';
      }
      if (noResults) {
        noResults.hidden = visible !== 0;
      }
    }

    if (!input.__tagFilterBound) {
      input.__tagFilterBound = true;
      input.addEventListener('input', filter);
    }

    filter();
  }

  document.addEventListener('astro:page-load', initTagFilter);
  initTagFilter();
</script>

<style>
  .tag-search-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .tag-filter-input {
    flex: 1;
    padding: 0.625rem 0.75rem;
    min-height: 44px;
    font-size: 0.875rem;
    font-family: inherit;
    border: 1px solid var(--theme-border);
    border-radius: 0.375rem;
    background: var(--theme-bg-elevated);
    color: var(--theme-text-primary);
    outline: none;
    transition: border-color 0.15s;
    box-sizing: border-box;
  }
  .tag-filter-input::placeholder {
    color: var(--theme-text-muted);
  }
  .tag-filter-input:hover {
    border-color: var(--theme-accent);
  }
  .tag-filter-input:focus {
    border-color: var(--theme-accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--theme-accent) 25%, transparent);
  }
  .tag-filter-count {
    font-size: 0.75rem;
    color: var(--theme-text-muted);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .tag-index-card {
    padding: 0.75rem;
    border: 1px solid var(--theme-border);
    background-color: var(--theme-bg-elevated);
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .tag-index-card:hover {
    border-color: var(--theme-accent);
  }
  .tag-no-results {
    padding: 2rem 0;
    text-align: center;
    font-size: 0.875rem;
    color: var(--theme-text-muted);
  }
</style>
