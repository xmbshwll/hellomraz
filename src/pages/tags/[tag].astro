---
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import {
  getDateIndex,
  getLinkedTagNames,
  getQualifiedTagPages,
} from '../../lib/blog-data.mjs';
import { TAG_PAGE_POST_CAP } from '../../lib/feed-limits.mjs';

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');

export async function getStaticPaths() {
  const [tagPages, linkedTagNames] = await Promise.all([
    getQualifiedTagPages(),
    getLinkedTagNames(),
  ]);

  return tagPages.map(({ name, posts }) => ({
    params: { tag: encodeURIComponent(name) },
    props: { posts, linkedTagNames, tagName: name },
  }));
}

interface Props {
  posts: CollectionEntry<'blog'>[];
  linkedTagNames: string[];
  tagName: string;
}

const { posts = [], linkedTagNames = [], tagName } = Astro.props as Props;
const tag = tagName;
const linkedTags = new Set<string>(linkedTagNames);
const dateIndex = await getDateIndex();
const sortedPosts = [...posts].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const relatedTags = [...new Set(
  sortedPosts.flatMap((post) => post.data.tags || [])
    .filter((value) => value !== tag && linkedTags.has(value))
)].slice(0, 5);

const visiblePosts = sortedPosts.slice(0, TAG_PAGE_POST_CAP);
const hasMore = sortedPosts.length > TAG_PAGE_POST_CAP;
---

<Layout title={`#${tag}`}>
  <div class="min-h-full theme-surface">
    <PageHeader dateIndex={dateIndex} />

    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
      <!-- Header -->
      <div class="mb-6">
        <a href={`${base}tags`} class="text-xs mb-3 inline-block theme-text-accent">
          ← tags/
        </a>

        <h1 class="text-2xl font-bold theme-text-primary">
          #{tag}
        </h1>
        <p class="text-sm mt-1 theme-text-muted">
          {sortedPosts.length} {sortedPosts.length === 1 ? 'post' : 'posts'}
        </p>
      </div>

      <!-- Related tags -->
      {relatedTags.length > 0 && (
        <div class="mb-6 pb-4 border-b theme-border">
          <div class="flex flex-wrap gap-1.5">
            {relatedTags.map((relatedTag) => (
              <a
                href={`${base}tags/${encodeURIComponent(relatedTag)}`}
                class="related-tag-chip"
              >
                #{relatedTag}
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Posts list (capped) -->
      <div class="space-y-0" id="tag-posts-list">
        {visiblePosts.map((post) => (
          <a
            href={`${base}blog/${post.slug}`}
            class="tag-post-row"
          >
            <span class="tag-post-date">
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' })}
            </span>
            <span class="tag-post-title">
              {post.data.title}
            </span>
          </a>
        ))}
      </div>

      <!-- Hidden posts loaded on demand -->
      {hasMore && (
        <div class="mt-4 text-center" id="tag-show-more-wrap">
          <button
            id="tag-show-more-btn"
            class="show-more-btn"
            data-tag={tag}
          >
            show all {sortedPosts.length} posts
          </button>
        </div>
      )}

      {sortedPosts.length === 0 && (
        <div class="py-8">
          <p class="text-sm theme-text-muted">no posts found.</p>
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .related-tag-chip {
    font-size: 0.75rem;
    padding: 0.125rem 0.5rem;
    border: 1px solid var(--theme-border);
    color: var(--theme-text-muted);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .related-tag-chip:hover {
    border-color: var(--theme-accent);
    color: var(--theme-accent);
  }
  .show-more-btn {
    padding: 0.5rem 1.25rem;
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid var(--theme-border);
    color: var(--theme-text-muted);
    background: var(--theme-bg-elevated);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .show-more-btn:hover {
    border-color: var(--theme-accent);
    color: var(--theme-accent);
  }
</style>

<style is:global>
  /* Global so dynamically inserted rows match server-rendered ones */
  .tag-post-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--theme-border);
    color: var(--theme-text-secondary);
    text-decoration: none;
    transition: color 0.15s, background-color 0.15s;
  }
  .tag-post-row:hover {
    color: var(--theme-text-primary);
    background-color: var(--theme-bg-hover);
  }
  .tag-post-date {
    font-size: 0.75rem;
    flex-shrink: 0;
    font-family: ui-monospace, monospace;
    color: var(--theme-text-muted);
  }
  .tag-post-title {
    font-size: 0.875rem;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }
  @media (max-width: 640px) {
    .tag-post-row {
      gap: 0.5rem;
      padding: 0.625rem 0;
      min-height: 44px;
      align-items: center;
    }
    .tag-post-title {
      white-space: normal;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
  }
</style>

<script>
  function initTagShowMore() {
    const btn = document.getElementById('tag-show-more-btn') as
      | (HTMLButtonElement & { __tagShowMoreBound?: boolean })
      | null;
    const list = document.getElementById('tag-posts-list');
    const wrap = document.getElementById('tag-show-more-wrap');
    if (!btn || !list || !wrap || btn.__tagShowMoreBound) return;

    btn.__tagShowMoreBound = true;
    const tag = btn.dataset.tag!;

    btn.addEventListener('click', async () => {
      btn.textContent = 'loading…';
      try {
        const base = document.querySelector('meta[name="base-url"]')?.getAttribute('content') || '/';
        const res = await fetch(`${base}api/tag-posts/${encodeURIComponent(tag)}.json`);
        const remainingPosts: { slug: string; title: string; date: string }[] = await res.json();

        for (const post of remainingPosts) {
          const a = document.createElement('a');
          a.href = `${base}blog/${post.slug}`;
          a.className = 'tag-post-row';
          const date = new Date(post.date);

          const dateSpan = document.createElement('span');
          dateSpan.className = 'tag-post-date';
          dateSpan.textContent = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' });

          const titleSpan = document.createElement('span');
          titleSpan.className = 'tag-post-title';
          titleSpan.textContent = post.title;

          a.appendChild(dateSpan);
          a.appendChild(titleSpan);
          list.appendChild(a);
        }
        wrap.remove();
      } catch {
        btn.textContent = 'failed to load';
      }
    });
  }

  document.addEventListener('astro:page-load', initTagShowMore);
  initTagShowMore();
</script>
