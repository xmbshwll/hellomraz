---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL || '/';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  
  // Get all unique tags
  const uniqueTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];
  
  // Create a path for each tag
  return uniqueTags.map(tag => {
    const filteredPosts = allPosts.filter(post => 
      post.data.tags?.some(t => t.toLowerCase() === tag.toLowerCase())
    );
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts = [] } = Astro.props;

// Sort posts by date
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Generate related tags
const relatedTags = [...new Set(
  sortedPosts.flatMap(post => post.data.tags || [])
    .filter(t => t !== tag)
)].slice(0, 5);
---

<BaseLayout title={`Posts tagged with "${tag}"`}>
  <div class="w-full max-w-3xl mx-auto py-10 sm:py-16">
    <!-- Header -->
    <div class="relative mb-10">
      <div class="absolute -top-20 -left-20 w-48 h-48 bg-zinc-100 dark:bg-zinc-900/30 rounded-full blur-3xl opacity-30 animate-blob"></div>
      
      <div class="relative">
        <a href={`${base}tags`} class="inline-flex items-center gap-2 text-sm text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          <span>Back to all tags</span>
        </a>
        
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-2">
          #{tag}
        </h1>
        
        <p class="text-zinc-600 dark:text-zinc-400">
          {sortedPosts.length} {sortedPosts.length === 1 ? 'article' : 'articles'}
        </p>
      </div>
    </div>
    
    <!-- Related tags -->
    {relatedTags.length > 0 && (
      <div class="mb-8">
        <h2 class="text-sm font-medium text-zinc-900 dark:text-zinc-100 mb-3">Related topics</h2>
        <div class="flex flex-wrap gap-2">
          {relatedTags.map(relatedTag => (
            <a 
              href={`${base}tags/${relatedTag}`}
              class="inline-flex items-center rounded-full px-3 py-1.5 text-sm font-medium bg-zinc-100 text-zinc-900 hover:bg-zinc-200 dark:bg-zinc-800 dark:text-zinc-100 dark:hover:bg-zinc-700 transition-colors"
            >
              #{relatedTag}
            </a>
          ))}
        </div>
      </div>
    )}
    
    <!-- Posts list -->
    <div class="space-y-8">
      {sortedPosts.map((post) => (
        <article class="group relative">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex-shrink-0 text-sm text-zinc-500 dark:text-zinc-400 w-20">
              {post.data.pubDate.toLocaleDateString('en-US', { 
                month: 'short', 
                day: 'numeric' 
              })}
            </div>
            
            <div class="flex-1">
              <h2 class="text-lg sm:text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-2 group-hover:text-zinc-700 dark:group-hover:text-zinc-300 transition-colors">
                <a href={`${base}blog/${post.slug}`}>
                  {post.data.title}
                </a>
              </h2>
              
              <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-3 line-clamp-2">
                {post.data.description}
              </p>
              
              {post.data.tags && (
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.slice(0, 3).map(postTag => (
                    <span class={`text-xs px-2 py-0.5 rounded-full ${
                      postTag === tag 
                        ? 'bg-zinc-900/10 text-zinc-900 dark:bg-zinc-100/20 dark:text-zinc-100' 
                        : 'bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400'
                    }`}>
                      #{postTag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
    
    <!-- Empty state -->
    {sortedPosts.length === 0 && (
      <div class="text-center py-12">
        <p class="text-xl text-zinc-600 dark:text-zinc-400">No posts found for this tag.</p>
        <a href={`${base}blog`} class="inline-flex items-center gap-2 mt-4 text-zinc-900 dark:text-zinc-100 hover:underline">
          Browse all articles
        </a>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  @keyframes blob {
    0% {
      transform: translate(0px, 0px) scale(1);
    }
    33% {
      transform: translate(20px, -20px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
    }
    100% {
      transform: translate(0px, 0px) scale(1);
    }
  }
  
  .animate-blob {
    animation: blob 7s infinite;
  }
  
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
