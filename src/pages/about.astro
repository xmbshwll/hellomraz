---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";

const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
---

<Layout title="About" description="О блоге Опусти Оружие, Мразь">
  <div class="min-h-full" style="background-color: var(--theme-bg-surface);">
    <PageHeader />

    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
      <!-- Header -->
      <div
        class="mb-8 border-b pb-4"
        style="border-color: var(--theme-border);"
      >
        <h1
          class="text-2xl font-bold"
          style="color: var(--theme-text-primary);"
        >
          $ whoami
        </h1>
        <p class="text-sm mt-2" style="color: var(--theme-text-muted);">
          music · reviews · underground
        </p>
      </div>

      <!-- About Section -->
      <div class="mb-8">
        <h2
          id="about-heading"
          class="text-lg font-bold mb-4"
          style="color: var(--theme-text-primary);"
        >
          ~ about
        </h2>

        <div
          id="about-text"
          class="space-y-3 text-sm"
          style="color: var(--theme-text-secondary);"
        >
          <p>
            Опусти Оружие, Мразь — самое лучшее во вселенной
            музыкально-критическое СМИ (возможно, после The Quietus).
          </p>
          <p>
            Быстрый DIY авторский блог в фристайл режиме. Жалобы не принимаются,
            восхищение музыкальным вкусом - напротив.
          </p>
        </div>
      </div>

      <!-- Contact -->
      <div class="border-t pt-6" style="border-color: var(--theme-border);">
        <h2
          id="links-heading"
          class="text-lg font-bold mb-4"
          style="color: var(--theme-text-primary);"
        >
          ~ links
        </h2>
        <ul
          class="space-y-1 text-sm"
          style="color: var(--theme-text-secondary);"
        >
          <li class="py-2">
            → telegram: <a
              href="https://t.me/hellomraz"
              class="inline-flex items-center"
              style="color: var(--theme-accent); min-height: 44px;"
              >@hellomraz</a
            >
          </li>
          <li class="py-2">
            → BlueSky: <a
              href="https://bsky.app/profile/xmbshwll.bsky.social"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center"
              style="color: var(--theme-accent); min-height: 44px;">@xmbshwll</a
            >
          </li>
        </ul>
      </div>

      <!-- Support -->
      <div
        class="border-t pt-6 mt-2"
        style="border-color: var(--theme-border);"
      >
        <h2
          id="support-heading"
          class="text-lg font-bold mb-4"
          style="color: var(--theme-text-primary);"
        >
          ~ support
        </h2>
        <a
          href="https://buymeacoffee.com/hellomraz"
          target="_blank"
          rel="noopener noreferrer"
          class="bmc-card"
        >
          <span class="bmc-icon">☕</span>
          <div>
            <div class="bmc-title">Buy Me a Coffee</div>
            <div class="bmc-url">buymeacoffee.com/hellomraz</div>
          </div>
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .bmc-card {
    display: flex;
    align-items: center;
    gap: 12px;
    border: 1px solid color-mix(in srgb, var(--theme-accent) 30%, transparent);
    border-radius: 8px;
    padding: 14px 18px;
    min-height: 44px;
    text-decoration: none;
    background: color-mix(in srgb, var(--theme-accent) 5%, transparent);
    transition:
      border-color 0.2s,
      background-color 0.2s;
  }
  .bmc-card:hover {
    border-color: var(--theme-accent);
    background: color-mix(in srgb, var(--theme-accent) 10%, transparent);
  }
  .bmc-icon {
    font-size: 22px;
    flex-shrink: 0;
  }
  .bmc-title {
    color: var(--theme-text-primary);
    font-size: 13px;
    font-weight: 600;
  }
  .bmc-url {
    color: var(--theme-text-muted);
    font-size: 11px;
    margin-top: 2px;
  }
</style>

<script>
  const translations: Record<
    string,
    { about: string; text: string; links: string; support: string }
  > = {
    ru: {
      about: "~ about",
      text: "<p>Опусти Оружие, Мразь — самое лучшее во вселенной музыкально-критическое СМИ (возможно, после The Quietus).</p><p>Быстрый DIY авторский блог в фристайл режиме. Жалобы не принимаются, восхищение музыкальным вкусом - напротив.</p><p>С любовью ПО ЕБАЛУ, из Берлина</p>",
      links: "~ links",
      support: "~ support",
    },
    en: {
      about: "~ about",
      text: "<p>Опусти Оружие, Мразь <i>(Drop Your Weapon, Scum)</i> — the best music criticism outlet in the universe (possibly after The Quietus).</p><p>A fast DIY freestyle blog. Complaints are not accepted; admiration for the musical taste, on the other hand, is welcome.</p><p>With love ПО ЕБАЛУ <i>(PUNCH IN THE FACE)</i>, from Berlin</p>",
      links: "~ links",
      support: "~ support",
    },
    de: {
      about: "~ about",
      text: "<p>Опусти Оружие, Мразь <i>(Leg die Waffe nieder, Mistkerl)</i> — das beste Musikkritik-Medium im Universum (möglicherweise nach The Quietus).</p><p>Ein schneller DIY-Freestyle-Blog. Beschwerden werden nicht angenommen; Bewunderung für den Musikgeschmack hingegen schon.</p><p>Mit Liebe ПО ЕБАЛУ <i>(INS GESICHT PUNCHEN)</i>, aus Berlin</p>",
      links: "~ links",
      support: "~ support",
    },
  };

  function updateAboutPage() {
    const lang = localStorage.getItem("site-lang") || "ru";
    const t = translations[lang] || translations.ru;

    const heading = document.getElementById("about-heading");
    const text = document.getElementById("about-text");
    const linksHeading = document.getElementById("links-heading");
    const supportHeading = document.getElementById("support-heading");

    if (heading) heading.textContent = t.about;
    if (text) text.innerHTML = t.text;
    if (linksHeading) linksHeading.textContent = t.links;
    if (supportHeading) supportHeading.textContent = t.support;
  }

  document.addEventListener("astro:page-load", updateAboutPage);
  window.addEventListener("lang-changed", updateAboutPage);
  updateAboutPage();
</script>
