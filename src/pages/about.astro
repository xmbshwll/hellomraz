---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL || '/';
---

<BaseLayout title="About Me" description="Learn more about my background, skills, and experience">
  <div class="max-w-3xl mx-auto py-8 sm:py-12 md:py-16">
    <!-- Hero Section -->
    <div class="relative mb-12 sm:mb-16">
      <div class="absolute -top-10 -left-10 w-48 h-48 bg-zinc-100 dark:bg-zinc-800/30 rounded-full blur-3xl opacity-30 animate-blob theme-transition-bg"></div>
      <div class="absolute -bottom-10 -right-10 w-48 h-48 bg-zinc-200 dark:bg-zinc-800/30 rounded-full blur-3xl opacity-30 animate-blob animation-delay-2000 theme-transition-bg"></div>
      
      <div class="relative text-center">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-6">
          Hello, I'm <span class="text-zinc-600 dark:text-zinc-400">a Developer</span>
        </h1>
        
        <p class="text-lg sm:text-xl text-zinc-600 dark:text-zinc-400 mb-8 leading-relaxed">
          I build things for the web and write about my experiences.
        </p>
      </div>
    </div>
    
    <!-- About Section -->
    <div class="mb-16 max-w-2xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold text-zinc-900 dark:text-zinc-100 mb-6">About Me</h2>
      
      <div class="prose prose-zinc dark:prose-invert max-w-none">
        <p class="text-base sm:text-lg leading-relaxed mb-4">
          Welcome to my blog! I'm a developer passionate about building things for the web. 
          This blog serves as both a personal journal and a resource for others who might find my experiences useful.
        </p>
        
        <p class="text-base sm:text-lg leading-relaxed mb-4">
          You can expect content on web development, JavaScript/TypeScript, tools & workflows, 
          and my journey as a developer.
        </p>
        
        <h3 class="text-xl font-bold mt-8 mb-4">Built With</h3>
        <p class="text-base sm:text-lg leading-relaxed mb-4">
          This blog is built with <a href="https://astro.build" class="text-blue-600 dark:text-blue-400">Astro</a>, 
          a fast static site generator that ships zero JavaScript by default. 
          It's hosted on GitHub Pages for free and easy deployment.
        </p>
        
        <h3 class="text-xl font-bold mt-8 mb-4">Get in Touch</h3>
        <ul class="space-y-2">
          <li>GitHub: <a href="https://github.com/hellomraz" class="text-blue-600 dark:text-blue-400">@hellomraz</a></li>
          <li>Email: your.email@example.com</li>
        </ul>
      </div>
    </div>
    
    <!-- Contact Section -->
    <div class="text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-zinc-900 dark:text-zinc-100 mb-4">Get in Touch</h2>
      <p class="text-base sm:text-lg text-zinc-600 dark:text-zinc-400 mb-6">
        I'm always open to new opportunities and collaborations.
      </p>
      
      <a 
        href="mailto:your.email@example.com" 
        class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-zinc-900 dark:bg-zinc-100 text-zinc-100 dark:text-zinc-900 hover:bg-zinc-700 dark:hover:bg-zinc-300 transition-colors text-base font-medium"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        Say Hello
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  @keyframes blob {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(5%, 5%) scale(1.05);
    }
    50% {
      transform: translate(0, 10%) scale(1);
    }
    75% {
      transform: translate(-5%, 5%) scale(0.95);
    }
  }
  
  .animate-blob {
    animation: blob 8s infinite ease;
  }
  
  .animation-delay-2000 {
    animation-delay: 2s;
  }
</style>
