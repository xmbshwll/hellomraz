---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import PostCard from "../../components/PostCard.astro";
import Pagination from "../../components/Pagination.astro";

const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");

const MONTH_LABELS = [
  "", "January", "February", "March", "April", "May", "June",
  "July", "August", "September", "October", "November", "December",
];

export const getStaticPaths = (async ({ paginate }) => {
  const pageSize = 24;
  const allPosts = await getCollection("blog");
  const sorted = allPosts
    .filter((p) => !p.data.draft)
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

  const pages = paginate(sorted, { pageSize });

  return pages;
}) satisfies GetStaticPaths;

const { page } = Astro.props;

// Group this page's posts by month for section headers
type MonthGroup = { key: string; label: string; posts: typeof page.data };
const monthGroups: MonthGroup[] = [];
let currentKey = "";

for (const post of page.data) {
  const d = post.data.pubDate;
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
  if (key !== currentKey) {
    currentKey = key;
    monthGroups.push({
      key,
      label: `${MONTH_LABELS[d.getMonth() + 1]} ${d.getFullYear()}`,
      posts: [],
    });
  }
  monthGroups[monthGroups.length - 1].posts.push(post);
}
---

<Layout title={page.currentPage === 1 ? "All Reviews" : `All Reviews — Page ${page.currentPage}`}>
  <div class="min-h-full" style="background-color: var(--theme-bg-surface);">
    <PageHeader />

    <div class="px-4 sm:px-6 pb-8" style="padding-bottom: calc(2rem + env(safe-area-inset-bottom, 0px));">
      <div class="mb-8">
        <div>
          <h1 class="text-3xl font-bold mb-2" style="color: var(--theme-text-primary);">All Reviews</h1>
          <p class="text-sm" style="color: var(--theme-text-muted);">
            {page.total} releases
            {page.lastPage > 1 && <span> · Page {page.currentPage} of {page.lastPage}</span>}
          </p>
        </div>
      </div>

      {(() => {
        let globalIndex = 0;
        return monthGroups.map((group) => (
          <section id={`month-${group.key}`} class="mb-8 scroll-mt-4">
            <h2
              class="text-lg font-semibold mb-4 pb-2 border-b"
              style="color: var(--theme-text-secondary); border-color: var(--theme-border);"
            >
              {group.label}
            </h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 gap-2 sm:gap-4">
              {group.posts.map((post) => <PostCard post={post} index={globalIndex++} />)}
            </div>
          </section>
        ));
      })()}

      {page.lastPage > 1 && (
        <Pagination
          currentPage={page.currentPage}
          lastPage={page.lastPage}
          baseUrl={`${base}blog`}
        />
      )}
    </div>
  </div>
</Layout>
