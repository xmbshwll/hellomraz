---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import StreamingPlayer from '../../components/StreamingPlayer.astro';
import AlbumMeta from '../../components/AlbumMeta.astro';
import ListenOn from '../../components/ListenOn.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getPostColor } from '../../lib/colors';
import { getBandcampData } from '../../lib/bandcamp';
import { getStreamingLinks } from '../../lib/streaming';
import { getAlbum, parseArtistAlbum } from '../../lib/albums';
import {
  getDateIndex,
  getLinkedTagNames,
  getPublishedPosts,
} from '../../lib/blog-data.mjs';
import '../../layouts/styles/markdown.css';

export async function getStaticPaths() {
  const [posts, linkedTagNames] = await Promise.all([
    getPublishedPosts(),
    getLinkedTagNames(),
  ]);

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, linkedTagNames },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
  linkedTagNames: string[];
}

const { post, linkedTagNames = [] } = Astro.props as Props;
const linkedTags = new Set(linkedTagNames);
const { Content } = await post.render();
const color = getPostColor(post.slug);
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const dateIndex = await getDateIndex();

// Build "cover art" initials
const initials = post.data.title
  .split(/[\s\-–—]+/)
  .slice(0, 2)
  .map((w: string) => w[0]?.toUpperCase() ?? '')
  .join('');

// Format date
const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Bandcamp embed
const bc = getBandcampData(post.slug);
const bcAlbumId = bc?.albumId;
const bcUrl = bc?.url;
const bcCover = bc?.coverUrl;

// Album metadata from albums.json
const albumEntry = getAlbum(post.slug);
const albumTags = albumEntry?.bcTags;

// Artist/album: prefer albums.json, fall back to parsing the post title
const parsed = parseArtistAlbum(post.data.title);
const albumArtist = albumEntry?.artist || parsed?.artist;
const albumName = albumEntry?.album || parsed?.album;

// Get all streaming links from pre-extracted data
const streamingLinks = getStreamingLinks(post.slug);

// Best available "buy/listen" link when no Bandcamp URL
const primaryLink = !bcUrl && streamingLinks.length > 0
  ? { service: streamingLinks[0].service, url: streamingLinks[0].url }
  : undefined;

// Social preview image — use cover (large version) or fallback
let ogImage: string | undefined;
if (bcCover) {
  if (bcCover.includes('bcbits.com')) {
    ogImage = bcCover.replace(/_5\.jpg$/, '_2.jpg');
  } else {
    ogImage = bcCover;
  }
}
const postDescription = post.data.description || `${post.data.title} — music review on poeba.lu`;
---

<Layout title={post.data.title} description={postDescription} image={ogImage} type="article">
  <div
    class="relative min-h-full flex flex-col overflow-x-hidden rounded-lg"
    style="background-color: var(--theme-bg-surface);"
    transition:name={`post-${post.slug}-box`}
    data-post-slug={post.slug}
  >
    <PageHeader dateIndex={dateIndex} />

    <!-- Header: cover art + metadata -->
    <div
      class="flex flex-col items-center md:flex-row md:items-end gap-6 px-4 sm:px-6 pb-6"
    >
      <!-- Cover art -->
      {
        bcCover ? (
          <Image
            src={bcCover}
            alt={post.data.title}
            width={208}
            height={208}
            class="h-36 w-36 sm:h-44 sm:w-44 md:h-52 md:w-52 flex-none rounded-md object-cover shadow-2xl"
            loading="lazy"
            transition:name={`post-${post.slug}-image`}
          />
        ) : (
          <div
            class="h-36 w-36 sm:h-44 sm:w-44 md:h-52 md:w-52 flex-none rounded-md flex items-center justify-center text-5xl font-bold text-white shadow-2xl"
            style={`background: linear-gradient(135deg, ${color.accent}cc, ${color.dark})`}
            transition:name={`post-${post.slug}-image`}
          >
            {initials}
          </div>
        )
      }

      <!-- Metadata -->
      <div class="flex flex-col gap-2 text-center md:text-left">
        <span
          class="text-xs font-semibold uppercase tracking-wider"
          style="color: var(--theme-text-secondary);">Review</span
        >
        <h1
          class="title-clamp font-extrabold leading-none"
          style="color: var(--theme-text-primary);"
          transition:name={`post-${post.slug}-title`}
        >
          {post.data.title}
        </h1>
        <div class="flex flex-wrap gap-1 mt-1" style="color: var(--theme-text-secondary);">
          {
            post.data.tags?.map((tag, i) => (
              <span>
                {linkedTags.has(tag) ? (
                  <a
                    href={`${base}tags/${tag}`}
                    class="hover:underline inline-block"
                    style="color: var(--theme-text-secondary); padding: 4px 0; min-height: 44px; line-height: 2;"
                  >
                    {tag}
                  </a>
                ) : (
                  <span
                    class="inline-block"
                    style="color: var(--theme-text-muted); padding: 4px 0; min-height: 44px; line-height: 2;"
                  >
                    {tag}
                  </span>
                )}
                {i < (post.data.tags?.length ?? 0) - 1 ? (
                  <span style="color: var(--theme-text-muted);">| </span>
                ) : (
                  ''
                )}
              </span>
            ))
          }
        </div>
        <div class="text-xs" style="color: var(--theme-text-muted);">
          {formattedDate}
        </div>
      </div>
    </div>

    <!-- Player + Content side by side -->
    <div class="flex flex-col md:flex-row px-4 sm:px-6 py-6 gap-0 overflow-x-hidden" style="max-width: 100%;">
      <!-- Streaming player (left) -->
      {
        streamingLinks.length > 0 && (
          <div class="flex-none pb-4 md:pb-0 md:pr-6" style="max-width: 100%;">
            <StreamingPlayer
              links={streamingLinks}
              bandcampAlbumId={bcAlbumId}
              bandcampUrl={bcUrl}
            />
          </div>
        )
      }

      <!-- Content area (right) -->
      <div
        class:list={[
          'flex-1 py-2 min-w-0',
          streamingLinks.length > 0 ? 'border-t md:border-t-0 md:border-l md:pl-6 pt-4 md:pt-2' : ''
        ]}
        style={`background-color: color-mix(in srgb, var(--theme-bg-surface) 60%, transparent); ${streamingLinks.length > 0 ? 'border-color: var(--theme-text-muted); --tw-border-opacity: 0.2;' : ''}`}
      >
        <div
          class="max-w-2xl markdown-content leading-relaxed"
          style="color: var(--theme-text-secondary);"
        >
          <Content />
        </div>

        {/* Album metadata, streaming links, and related posts */}
        <AlbumMeta
          artist={albumArtist}
          album={albumName}
          tags={albumTags ?? post.data.tags ?? []}
          date={post.data.pubDate}
          releaseDate={albumEntry?.releaseDate}
          bandcampUrl={bcUrl ?? undefined}
          primaryLink={primaryLink}
          linkedTags={linkedTags}
        />

        <ListenOn
          links={streamingLinks}
          bandcampUrl={bcUrl ?? undefined}
        />

        <RelatedPosts
          currentSlug={post.slug}
          tags={post.data.tags ?? []}
        />
      </div>
    </div>

    <!-- Background gradient (context color) -->
    <div
      class="absolute top-0 inset-x-0 h-80 z-[-1]"
      style={`background: linear-gradient(to bottom, ${color.dark}cc, transparent)`}
    >
      <div
        class="el-to-fade transition-all duration-500 absolute inset-0 scale-90 opacity-30 blur-2xl"
        style={`background: radial-gradient(ellipse at 30% 0%, ${color.accent}55, transparent 70%)`}
      >
      </div>
    </div>
  </div>
</Layout>

<style>
  .title-clamp {
    font-size: clamp(1.5rem, 5vw, 3.5rem);
    line-height: 1.1;
  }
  /* Override markdown-content link colors */
  .markdown-content a {
    color: var(--theme-accent) !important;
  }
  .markdown-content a:hover {
    color: var(--theme-accent-hover) !important;
    border-bottom-color: var(--theme-accent-hover) !important;
  }
</style>
