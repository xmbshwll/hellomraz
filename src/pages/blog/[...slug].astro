---
import { Image } from 'astro:assets';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import StreamingPlayer from '../../components/StreamingPlayer.astro';
import AlbumMeta from '../../components/AlbumMeta.astro';
import ListenOn from '../../components/ListenOn.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getPostColor } from '../../lib/colors';
import { getBandcampData } from '../../lib/bandcamp';
import { getStreamingLinks } from '../../lib/streaming';
import { getAlbum, getCoverThumb, parseArtistAlbum } from '../../lib/albums';
import {
  getDateIndex,
  getLinkedTagNames,
  getPublishedPosts,
} from '../../lib/blog-data.mjs';
import { encodeTagParam } from '../../lib/tag-path';
import '../../layouts/styles/markdown.css';

export async function getStaticPaths() {
  const [posts, linkedTagNames] = await Promise.all([
    getPublishedPosts(),
    getLinkedTagNames(),
  ]);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, linkedTagNames },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
  linkedTagNames: string[];
}

const { post, linkedTagNames = [] } = Astro.props as Props;
const slug = post.id;
const postTitle = post.data.title;
const postTags = post.data.tags ?? [];
const linkedTags = new Set(linkedTagNames);
const { Content } = await render(post);
const color = getPostColor(slug);
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const dateIndex = await getDateIndex();

const initials = postTitle
  .split(/[\s\-–—]+/)
  .slice(0, 2)
  .map((word: string) => word[0]?.toUpperCase() ?? '')
  .join('');

const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const bc = getBandcampData(slug);
const bcAlbumId = bc?.albumId;
const bcUrl = bc?.url;
const bcCover = bc?.coverUrl;
const playerCover = getCoverThumb(slug, 'md') ?? bcCover;

const albumEntry = getAlbum(slug);
const albumTags = albumEntry?.bcTags;
const parsed = parseArtistAlbum(postTitle);
const albumArtist = albumEntry?.artist || parsed?.artist;
const albumName = albumEntry?.album || parsed?.album;

const streamingLinks = getStreamingLinks(slug);
const hasStreamingLinks = streamingLinks.length > 0;
const displayTags = albumTags ?? postTags;
const contentClassList = ['post-page-content flex-1 py-2 min-w-0'];

if (hasStreamingLinks) {
  contentClassList.push(
    'post-page-content-with-player border-t md:border-t-0 md:border-l md:pl-6 pt-4 md:pt-2',
  );
}

let primaryLink:
  | {
      service: string;
      url: string;
    }
  | undefined;

if (!bcUrl && hasStreamingLinks) {
  primaryLink = {
    service: streamingLinks[0].service,
    url: streamingLinks[0].url,
  };
}

let ogImage: string | undefined;
if (bcCover) {
  ogImage = bcCover.includes('bcbits.com')
    ? bcCover.replace(/_5\.jpg$/, '_2.jpg')
    : bcCover;
}

const postDescription = post.data.description || `${postTitle} — music review on poeba.lu`;
---

<Layout title={postTitle} description={postDescription} image={ogImage} type="article">
  <div
    class="post-page relative min-h-full flex flex-col overflow-x-hidden rounded-lg theme-surface"
    transition:name={`post-${slug}-box`}
    data-post-slug={slug}
  >
    <PageHeader dateIndex={dateIndex} />

    <!-- Header: cover art + metadata -->
    <div
      class="flex flex-col items-center md:flex-row md:items-end gap-6 px-4 sm:px-6 pb-6"
    >
      <!-- Cover art -->
      {
        bcCover ? (
          <Image
            src={bcCover}
            alt={postTitle}
            width={208}
            height={208}
            class="h-36 w-36 sm:h-44 sm:w-44 md:h-52 md:w-52 flex-none rounded-md object-cover shadow-2xl"
            loading="lazy"
            transition:name={`post-${slug}-image`}
          />
        ) : (
          <div
            class="post-cover-placeholder h-36 w-36 sm:h-44 sm:w-44 md:h-52 md:w-52 flex-none rounded-md flex items-center justify-center text-5xl font-bold text-white shadow-2xl"
            transition:name={`post-${slug}-image`}
          >
            {initials}
          </div>
        )
      }

      <!-- Metadata -->
      <div class="flex flex-col gap-2 text-center md:text-left">
        <span class="text-xs font-semibold uppercase tracking-wider theme-text-secondary">Review</span>
        <h1
          class="title-clamp font-extrabold leading-none theme-text-primary"
          transition:name={`post-${slug}-title`}
        >
          {postTitle}
        </h1>
        <div class="post-tag-list flex flex-wrap gap-x-0 gap-y-1 mt-1 theme-text-secondary">
          {
            postTags.map((tag, i) => (
              <span>{linkedTags.has(tag) ? (<a href={`${base}tags/${encodeTagParam(tag)}`} class="post-tag-link hover:underline inline-block">{tag}</a>) : (<span class="post-tag-text inline-block">{tag}</span>)}{i < postTags.length - 1 ? <span class="post-tag-separator">|</span> : null}</span>
            ))
          }
        </div>
        <div class="text-xs theme-text-muted">
          {formattedDate}
        </div>
      </div>
    </div>

    <!-- Player + Content side by side -->
    <div class="post-page-body flex flex-col md:flex-row px-4 sm:px-6 py-6 gap-0 overflow-x-hidden">
      <!-- Streaming player (left) -->
      {
        hasStreamingLinks && (
          <div class="post-page-player-slot flex-none pb-4 md:pb-0 md:pr-6">
            <StreamingPlayer
              links={streamingLinks}
              bandcampAlbumId={bcAlbumId}
              coverUrl={playerCover}
              slug={slug}
              title={postTitle}
            />
          </div>
        )
      }

      <!-- Content area (right) -->
      <div
        class:list={contentClassList}
      >
        <div class="max-w-2xl markdown-content leading-relaxed theme-text-secondary">
          <Content />
        </div>

        {/* Album metadata, streaming links, and related posts */}
        <AlbumMeta
          artist={albumArtist}
          album={albumName}
          tags={displayTags}
          date={post.data.pubDate}
          releaseDate={albumEntry?.releaseDate}
          bandcampUrl={bcUrl ?? undefined}
          primaryLink={primaryLink}
          linkedTags={linkedTags}
        />

        <ListenOn links={streamingLinks} />

        <RelatedPosts
          currentSlug={slug}
          tags={postTags}
        />
      </div>
    </div>

    <!-- Background gradient (context color) -->
    <div class="post-context-backdrop absolute top-0 inset-x-0 h-80 z-[-1]">
      <div
        class="post-context-glow el-to-fade transition-all duration-500 absolute inset-0 scale-90 opacity-30 blur-2xl"
      >
      </div>
    </div>
  </div>
</Layout>

<style define:vars={{
  postCoverGradientStart: `${color.accent}cc`,
  postCoverGradientEnd: color.dark,
  postContextGradient: `${color.dark}cc`,
  postContextGlow: `${color.accent}55`,
}}>
  .title-clamp {
    font-size: clamp(1.5rem, 5vw, 3.5rem);
    line-height: 1.1;
  }
  .post-tag-link,
  .post-tag-text {
    padding: 4px 0;
    min-height: 44px;
    line-height: 2;
  }
  .post-tag-link {
    color: var(--theme-text-secondary);
    text-decoration: none;
  }
  .post-tag-text,
  .post-tag-separator {
    color: var(--theme-text-muted);
  }
  .post-page-body,
  .post-page-player-slot {
    max-width: 100%;
  }
  .post-page-content {
    background-color: color-mix(in srgb, var(--theme-bg-surface) 60%, transparent);
  }
  .post-page-content-with-player {
    border-color: color-mix(in srgb, var(--theme-text-muted) 20%, transparent);
  }
  .post-cover-placeholder {
    background: linear-gradient(
      135deg,
      var(--postCoverGradientStart),
      var(--postCoverGradientEnd)
    );
  }
  .post-context-backdrop {
    background: linear-gradient(to bottom, var(--postContextGradient), transparent);
  }
  .post-context-glow {
    background: radial-gradient(
      ellipse at 30% 0%,
      var(--postContextGlow),
      transparent 70%
    );
  }
  /* Override markdown-content link colors */
  .markdown-content a {
    color: var(--theme-accent) !important;
  }
  .markdown-content a:hover {
    color: var(--theme-accent-hover) !important;
    border-bottom-color: var(--theme-accent-hover) !important;
  }
</style>
