---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import PostCard from "../components/PostCard.astro";

const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");

const allPosts = await getCollection("blog");
const sorted = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const INITIAL_MORE = 24;
const morePosts = sorted.slice(0, INITIAL_MORE);
---

<Layout title="Home">
  <div
    id="playlist-container"
    style="background-color: var(--theme-bg-surface);"
  >
    <PageHeader />
  </div>

  <!-- Reviews -->
  <div class="reviews-section" style="background-color: var(--theme-bg-surface);">
    <div class="flex items-center justify-between mb-4 border-b pb-2" style="border-color: var(--theme-border);">
      <h2 class="text-lg font-bold" style="color: var(--theme-text-primary);">~ reviews</h2>
      <a
        href={`${base}blog`}
        class="text-sm font-medium inline-flex items-center"
        style="color: var(--theme-accent); min-height: 44px; padding: 8px 0;"
      >
        see all →
      </a>
    </div>
    <div
      class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 gap-2 sm:gap-3"
      id="more-reviews-grid"
      data-base={base}
    >
      {morePosts.map((post, i) => (
        <PostCard post={post} index={i} />
      ))}
    </div>

    <div class="flex justify-center mt-6" id="load-more-reviews-wrap">
      <button
        id="load-more-reviews-btn"
        class="load-more-reviews-btn"
      >
        load more
      </button>
    </div>
  </div>
</Layout>

<script>
  interface ReviewPost {
    slug: string;
    title: string;
    tags: string[];
    coverLg: string | null;
    colorDark: string;
    colorAccent: string;
    initials: string;
  }

  const BATCH = 12;
  const INITIAL_MORE = 24;
  let allPosts: ReviewPost[] | null = null;
  let rendered = INITIAL_MORE;

  function renderCard(post: ReviewPost, base: string): string {
    const safeTitle = post.title.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    const cover = post.coverLg
      ? `<img src="${post.coverLg}" alt="${safeTitle}" width="300" height="300"
           class="post-card-img" loading="lazy" decoding="async">`
      : `<div class="post-card-placeholder"
           style="background-color:${post.colorDark};color:${post.colorAccent};">${post.initials}</div>`;

    const tags = post.tags.slice(0, 3).join(' · ');

    return `<a href="${base}blog/${post.slug}"
      class="post-card playlist-item" data-color="${post.colorDark}">
      <div class="post-card-cover">${cover}</div>
      <div class="post-card-title">${safeTitle}</div>
      <div class="post-card-tags">${tags}</div>
    </a>`;
  }

  async function fetchPosts(): Promise<ReviewPost[]> {
    if (allPosts) return allPosts;
    const grid = document.getElementById("more-reviews-grid");
    const base = grid?.dataset.base || "/";
    const res = await fetch(`${base}api/recent-posts.json`);
    allPosts = await res.json();
    return allPosts!;
  }

  function initMoreReviews() {
    const btn = document.getElementById("load-more-reviews-btn");
    const wrap = document.getElementById("load-more-reviews-wrap");
    const grid = document.getElementById("more-reviews-grid");
    if (!btn || !wrap || !grid) return;

    // Reset state on page-load (view transitions may persist DOM)
    if ((btn as any).__bound) return;
    (btn as any).__bound = true;

    btn.addEventListener("click", async () => {
      btn.textContent = "loading…";
      const posts = await fetchPosts();
      const base = grid.dataset.base || "/";
      const end = Math.min(rendered + BATCH, posts.length);

      if (rendered >= posts.length) {
        wrap.style.display = "none";
        return;
      }

      const fragment = document.createDocumentFragment();
      for (let i = rendered; i < end; i++) {
        const div = document.createElement("div");
        div.innerHTML = renderCard(posts[i], base);
        fragment.appendChild(div.firstElementChild!);
      }
      grid.appendChild(fragment);
      rendered = end;

      if (rendered >= posts.length) {
        wrap.style.display = "none";
      } else {
        btn.textContent = "load more";
      }
    });
  }

  document.addEventListener("astro:page-load", initMoreReviews);
  initMoreReviews();
</script>

<style>
  .reviews-section {
    padding: 1.5rem 1rem 2rem;
    /* Add safe area inset for iPhone home indicator */
    padding-bottom: calc(2rem + env(safe-area-inset-bottom, 0px));
  }
  @media (min-width: 640px) {
    .reviews-section {
      padding: 1.5rem 1.5rem 2rem;
      padding-bottom: calc(2rem + env(safe-area-inset-bottom, 0px));
    }
  }
  .load-more-reviews-btn {
    padding: 0.75rem 1.25rem;
    min-height: 44px;
    font-size: 0.875rem;
    font-weight: 500;
    border: 1px solid var(--theme-border);
    color: var(--theme-text-secondary);
    background: var(--theme-bg-elevated);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .load-more-reviews-btn:hover {
    border-color: var(--theme-accent);
    color: var(--theme-accent);
  }
</style>

<style is:global>
  /* PostCard styles — global so both server-rendered and JS-injected cards match */
  .post-card {
    display: flex;
    flex-direction: column;
    outline: none;
    padding: 0.5rem;
    border: 1px solid var(--theme-border);
    background-color: var(--theme-bg-elevated);
    text-decoration: none;
    transition: border-color 0.15s;
  }
  @media (min-width: 641px) {
    .post-card {
      padding: 0.75rem;
    }
  }
  .post-card:hover {
    border-color: var(--theme-accent);
  }
  .post-card-cover {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    margin-bottom: 0.75rem;
  }
  .post-card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 1px solid var(--theme-border);
  }
  .post-card-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.25rem;
    font-weight: 700;
    border: 1px solid var(--theme-border);
  }
  .post-card-title {
    font-weight: 700;
    font-size: 0.875rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--theme-text-primary);
  }
  .post-card-tags {
    font-size: 0.75rem;
    margin-top: 0.25rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--theme-text-muted);
  }
</style>

<script>
  /* Hover-color effect for cards */
  function bindColorCards() {
    const container = document.getElementById("playlist-container");
    if (!container) return;

    function setColor(color: string) {
      const current = container!.getAttribute("data-color");
      if (color && color !== current) {
        container!.style.setProperty("--context-color", color);
        container!.setAttribute("data-color", color);
      }
    }

    let timeout: ReturnType<typeof setTimeout> | null = null;
    for (const card of document.querySelectorAll(".playlist-item")) {
      card.addEventListener("mouseover", () => {
        const c = card.getAttribute("data-color");
        if (!c) return;
        timeout = setTimeout(() => setColor(c), 200);
      });
      card.addEventListener("mouseout", () => {
        if (timeout) { clearTimeout(timeout); timeout = null; }
      });
      card.addEventListener("focus", () => {
        const c = card.getAttribute("data-color");
        if (c) setColor(c);
      });
    }
  }
  document.addEventListener("astro:page-load", bindColorCards);
  bindColorCards();
</script>
