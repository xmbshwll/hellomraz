---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import PostCard from '../components/PostCard.astro';

import { getDateIndex, getRecentPosts } from '../lib/blog-data.mjs';
import { getAllVideos } from '../lib/videos';
import { HOME_REVIEW_INITIAL_POSTS, HOME_VIDEO_INITIAL_POSTS } from '../lib/feed-limits.mjs';

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');

const [dateIndex, morePosts, allVideos] = await Promise.all([
  getDateIndex(),
  getRecentPosts(HOME_REVIEW_INITIAL_POSTS),
  Promise.resolve(getAllVideos()),
]);
const initialVideos = allVideos.slice(0, HOME_VIDEO_INITIAL_POSTS);
---

<Layout title="Home">
  <div id="playlist-container" class="theme-surface">
    <PageHeader dateIndex={dateIndex} />

    {initialVideos.length > 0 && (
      <div class="videos-strip theme-border" id="home-videos-strip">
        <!-- Collapsible header -->
        <div class="videos-strip-header">
          <span class="videos-strip-title">~ videos</span>
          <div class="flex items-center gap-2">
            <a href={`${base}videos`} class="videos-strip-link">see all →</a>
            <button
              type="button"
              class="videos-strip-toggle"
              aria-expanded="true"
              aria-label="Toggle videos strip"
            >
              <span class="videos-strip-chevron" aria-hidden="true">▾</span>
            </button>
          </div>
        </div>
        <!-- Collapsible body -->
        <div class="videos-strip-body" id="home-videos-scroll">
          {initialVideos.map((v, i) => (
            <a
              href={`${base}videos/${v.youtubeId}`}
              class="video-strip-card"
              data-youtube-id={v.youtubeId}
            >
              <div class="video-strip-thumb">
                <img
                  src={`https://i.ytimg.com/vi/${v.youtubeId}/hqdefault.jpg`}
                  alt={v.title}
                  width={320}
                  height={180}
                  loading={i < 4 ? 'eager' : 'lazy'}
                  decoding="async"
                />
                <div class="video-strip-play">▶</div>
              </div>
              <span class="video-strip-title">{v.title}</span>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>

  <div class="reviews-section theme-surface">
    <div class="flex items-center justify-between mb-4 border-b pb-2 theme-border">
      <h2 class="text-lg font-bold theme-text-primary">~ reviews</h2>
      <a
        href={`${base}blog`}
        class="reviews-link text-sm font-medium touch-target-inline theme-text-accent"
      >
        see all →
      </a>
    </div>
    <div
      class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 gap-2 sm:gap-3"
      id="more-reviews-grid"
      data-base={base}
    >
      {morePosts.map((post, i) => (
        <PostCard post={post} index={i} />
      ))}
    </div>

    <div class="flex justify-center mt-6" id="load-more-reviews-wrap">
      <button
        id="load-more-reviews-btn"
        class="load-more-reviews-btn"
      >
        load more
      </button>
    </div>
  </div>

</Layout>

<script>
  interface ReviewPost {
    slug: string;
    title: string;
    tags: string[];
    coverLg: string | null;
    colorDark: string;
    colorAccent: string;
    initials: string;
  }

  const BATCH = 12;
  let allPosts: ReviewPost[] | null = null;
  let loaded = 0;

  function escapeHtml(value: string): string {
    return value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function renderCard(post: ReviewPost, base: string): string {
    const safeTitle = escapeHtml(post.title);
    const safeInitials = escapeHtml(post.initials);
    const gradientId = `post-card-gradient-${post.slug}`;
    const cover = post.coverLg
      ? `<img src="${post.coverLg}" alt="${safeTitle}" width="300" height="300"
           class="post-card-img" loading="lazy" decoding="async">`
      : `<div class="post-card-placeholder" aria-hidden="true">
           <svg class="post-card-placeholder-art" viewBox="0 0 100 100" preserveAspectRatio="none" focusable="false">
             <defs>
               <linearGradient id="${gradientId}" x1="0%" y1="0%" x2="100%" y2="100%">
                 <stop offset="0%" stop-color="${post.colorDark}"></stop>
                 <stop offset="100%" stop-color="${post.colorAccent}"></stop>
               </linearGradient>
             </defs>
             <rect width="100" height="100" fill="url(#${gradientId})"></rect>
             <text x="50" y="54" fill="${post.colorAccent}" font-size="26" font-weight="700" text-anchor="middle" dominant-baseline="middle" font-family="JetBrains Mono, Fira Code, SF Mono, Cascadia Code, ui-monospace, monospace">${safeInitials}</text>
           </svg>
         </div>`;

    const tags = post.tags.slice(0, 3).join(' · ');

    return `<a href="${base}blog/${post.slug}"
      class="post-card playlist-item" data-color="${post.colorDark}">
      <div class="post-card-cover">${cover}</div>
      <div class="post-card-title">${safeTitle}</div>
      <div class="post-card-tags">${tags}</div>
    </a>`;
  }

  async function fetchPosts(): Promise<ReviewPost[]> {
    if (allPosts) return allPosts;
    const grid = document.getElementById('more-reviews-grid');
    const base = grid?.dataset.base || '/';
    const res = await fetch(`${base}api/review-cards.json`);
    allPosts = await res.json();
    return allPosts!;
  }

  function initMoreReviews() {
    const btn = document.getElementById('load-more-reviews-btn');
    const wrap = document.getElementById('load-more-reviews-wrap');
    const grid = document.getElementById('more-reviews-grid');
    if (!btn || !wrap || !grid) return;

    if ((btn as any).__bound) return;
    (btn as any).__bound = true;

    loaded = 0;
    wrap.hidden = false;
    btn.textContent = 'load more';

    btn.addEventListener('click', async () => {
      btn.textContent = 'loading…';
      const posts = await fetchPosts();
      const base = grid.dataset.base || '/';
      const end = Math.min(loaded + BATCH, posts.length);

      if (loaded >= posts.length) {
        wrap.hidden = true;
        return;
      }

      grid.insertAdjacentHTML(
        'beforeend',
        posts.slice(loaded, end).map((post) => renderCard(post, base)).join(''),
      );
      loaded = end;

      if (loaded >= posts.length) {
        wrap.hidden = true;
      } else {
        btn.textContent = 'load more';
      }
    });
  }

  document.addEventListener('astro:page-load', initMoreReviews);
  initMoreReviews();
</script>

<style>
  .reviews-section {
    padding: 1.5rem 1rem 2rem;
    padding-bottom: calc(2rem + env(safe-area-inset-bottom, 0px));
  }
  @media (min-width: 640px) {
    .reviews-section {
      padding: 1.5rem 1.5rem 2rem;
      padding-bottom: calc(2rem + env(safe-area-inset-bottom, 0px));
    }
  }
  .reviews-link {
    padding: 8px 0;
    text-decoration: none;
  }
  .load-more-reviews-btn {
    padding: 0.75rem 1.25rem;
    min-height: 44px;
    font-size: 0.875rem;
    font-weight: 500;
    border: 1px solid var(--theme-border);
    color: var(--theme-text-secondary);
    background: var(--theme-bg-elevated);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .load-more-reviews-btn:hover {
    border-color: var(--theme-accent);
    color: var(--theme-accent);
  }

  /* ── Videos horizontal strip (Netflix-style, collapsible) ── */
  .videos-strip {
    border-bottom: 1px solid var(--theme-border);
  }
  @media (min-width: 640px) {
    .videos-strip { padding: 0.75rem 1.5rem 1rem; }
  }

  /* Header — always visible */
  .videos-strip-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    transition: background-color 0.15s;
  }
  @media (min-width: 640px) {
    .videos-strip-header { padding: 0.75rem 1.5rem; }
  }
  .videos-strip-header:hover {
    background-color: var(--theme-bg-hover);
  }

  /* Body — collapsible flex scroll */
  .videos-strip-body {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    max-height: 600px;
    transition: max-height 0.25s ease, opacity 0.2s ease;
    opacity: 1;
    scrollbar-width: none;
  }
  .videos-strip-body::-webkit-scrollbar { display: none; }
  .videos-strip-body.videos-collapsed {
    max-height: 0 !important;
    opacity: 0;
  }

  /* Toggle button */
  .videos-strip-toggle {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
  }

  /* Chevron */
  .videos-strip-chevron {
    font-size: 1.25rem;
    color: var(--theme-text-muted);
    transition: transform 0.2s ease, color 0.15s;
  }
  .videos-strip-toggle[aria-expanded="false"] .videos-strip-chevron {
    transform: rotate(-90deg);
  }

  .video-strip-card {
    flex: 0 0 auto;
    min-width: 280px;
    max-width: 280px;
    scroll-snap-align: start;
    text-decoration: none;
    transition: transform 0.15s;
  }
  @media (min-width: 640px) {
    .video-strip-card { min-width: 320px; max-width: 320px; }
  }
  .video-strip-card:hover {
    transform: scale(1.03);
  }
  .video-strip-thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border: 1px solid var(--theme-border);
    background-color: var(--theme-bg-elevated);
  }
  .video-strip-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .video-strip-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.35);
    color: #fff;
    font-size: 1.75rem;
    opacity: 0;
    transition: opacity 0.15s;
    pointer-events: none;
  }
  .video-strip-card:hover .video-strip-play {
    opacity: 1;
  }
  .video-strip-title {
    display: block;
    margin-top: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--theme-text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>

<script>
  function bindColorCards() {
    const container = document.getElementById('playlist-container');
    const grid = document.getElementById('more-reviews-grid') as
      | (HTMLElement & {
          __colorCardsBound?: boolean;
        })
      | null;
    if (!container || !grid || grid.__colorCardsBound) return;

    grid.__colorCardsBound = true;

    function setColor(color: string) {
      const current = container.getAttribute('data-color');
      if (color && color !== current) {
        container.style.setProperty('--context-color', color);
        container.setAttribute('data-color', color);
      }
    }

    let timeout: ReturnType<typeof setTimeout> | null = null;

    grid.addEventListener('mouseover', (event) => {
      const card = (event.target as HTMLElement).closest<HTMLElement>('.playlist-item');
      if (!card) return;

      const related = event.relatedTarget;
      if (related instanceof Node && card.contains(related)) return;

      const color = card.getAttribute('data-color');
      if (!color) return;

      if (timeout) clearTimeout(timeout);
      timeout = setTimeout(() => setColor(color), 200);
    });

    grid.addEventListener('mouseout', (event) => {
      const card = (event.target as HTMLElement).closest<HTMLElement>('.playlist-item');
      if (!card) return;

      const related = event.relatedTarget;
      if (related instanceof Node && card.contains(related)) return;

      if (timeout) {
        clearTimeout(timeout);
        timeout = null;
      }
    });

    grid.addEventListener('focusin', (event) => {
      const card = (event.target as HTMLElement).closest<HTMLElement>('.playlist-item');
      if (!card) return;
      const color = card.getAttribute('data-color');
      if (color) setColor(color);
    });
  }

  document.addEventListener('astro:page-load', bindColorCards);
  bindColorCards();

  /* ── Videos strip collapsible ── */
  function initVideosStrip() {
    const strip = document.getElementById('home-videos-strip');
    if (!strip) return;

    const toggle = strip.querySelector('.videos-strip-toggle') as HTMLButtonElement | null;
    const body = strip.querySelector('.videos-strip-body') as HTMLElement | null;
    if (!toggle || !body) return;

    // Restore state from localStorage
    const collapsed = localStorage.getItem('hellomraz-videos-collapsed') === '1';
    if (collapsed) {
      body.classList.add('videos-collapsed');
      toggle.setAttribute('aria-expanded', 'false');
    }

    // Toggle on click
    toggle.addEventListener('click', () => {
      const isCollapsed = body.classList.toggle('videos-collapsed');
      toggle.setAttribute('aria-expanded', isCollapsed ? 'false' : 'true');
      localStorage.setItem('hellomraz-videos-collapsed', isCollapsed ? '1' : '0');
    });
  }

  document.addEventListener('astro:page-load', initVideosStrip);
  initVideosStrip();
</script>
