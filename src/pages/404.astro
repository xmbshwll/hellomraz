---
import Layout from '../layouts/Layout.astro';
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
---

<Layout title="404">
  <div class="flex flex-col items-center justify-center min-h-[60vh] py-20 text-center px-6">
    <pre class="text-6xl font-bold mb-4 theme-text-error">404</pre>
    <p class="text-sm mb-6 theme-text-muted">
      error: page not found
    </p>
    
    <div class="flex gap-2">
      <a href={base} class="err-btn err-btn-primary">→ home</a>
      <button id="back-btn" class="err-btn err-btn-secondary">← back</button>
    </div>
  </div>
</Layout>

<style>
  .err-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--theme-border);
    font-size: 0.875rem;
    transition: border-color 0.15s, color 0.15s;
    cursor: pointer;
  }
  .err-btn-primary {
    color: var(--theme-text-primary);
    background-color: var(--theme-bg-elevated);
  }
  .err-btn-secondary {
    color: var(--theme-text-muted);
    background: transparent;
  }
  .err-btn:hover {
    border-color: var(--theme-accent);
    color: var(--theme-accent);
  }
</style>

<script>
  const backButton = document.getElementById('back-btn') as
    | (HTMLButtonElement & { __backBound?: boolean })
    | null;

  if (backButton && !backButton.__backBound) {
    backButton.__backBound = true;
    backButton.addEventListener('click', () => history.back());
  }
</script>
