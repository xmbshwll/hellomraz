---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getDateIndex } from '../../lib/blog-data.mjs';
import { getAllVideos, getVideoThumb } from '../../lib/videos';
import { VIDEO_STRIP_INITIAL, VIDEO_PAGE_LOAD_MORE } from '../../lib/video-config.mjs';

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const dateIndex = await getDateIndex();
const allVideos = getAllVideos();
const initialVideos = allVideos.slice(0, VIDEO_STRIP_INITIAL);

function fmtDate(d: string): string {
  try {
    return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  } catch {
    return d;
  }
}
---

<Layout title="All Videos">
  <div class="min-h-full theme-surface">
    <PageHeader dateIndex={dateIndex} />

    <div class="px-4 sm:px-6 pb-8 safe-bottom-pad">
      <div class="mb-8">
        <h1 class="text-3xl font-bold mb-2 theme-text-primary">All Videos</h1>
        <p class="text-sm theme-text-muted">
          {allVideos.length} {allVideos.length === 1 ? 'video' : 'videos'}
        </p>
      </div>

    <div class="video-list" id="videos-list" data-base={base}>
      {initialVideos.map((v, i) => (
        <a href={`${base}videos/${v.youtubeId}`} class="video-row" data-youtube-id={v.youtubeId}>
          <div class="video-row-thumb">
            <img
              src={getVideoThumb(v.youtubeId, 'hq')}
              alt={v.title}
              loading={i < 4 ? 'eager' : 'lazy'}
              decoding="async"
              width="320"
              height="180"
            />
            <div class="video-row-play" aria-hidden="true">▶</div>
          </div>
          <div class="video-row-body">
            <div class="video-row-title">{v.title}</div>
            <div class="video-row-meta">
              <span class="video-row-date">{fmtDate(v.pubDate)}</span>
              {v.tags && v.tags.length > 0 && (
                <>
                  <span class="video-row-sep">·</span>
                  <span class="video-row-tags">{v.tags.slice(0, 4).join(' · ')}</span>
                </>
              )}
            </div>
            {v.description && (
              <div class="video-row-desc">{v.description}</div>
            )}
          </div>
        </a>
      ))}
    </div>

    {allVideos.length > VIDEO_STRIP_INITIAL && (
      <div class="flex justify-center mt-6" id="load-more-videos-wrap">
        <button id="load-more-videos-btn" class="load-more-reviews-btn">
          load more
        </button>
      </div>
    )}
    </div>
  </div>
</Layout>

<script>
  import { VIDEO_PAGE_LOAD_MORE } from '../../lib/video-config.mjs';

  interface VideoItem {
    slug: string;
    title: string;
    youtubeId: string;
    pubDate: string;
    tags?: string[];
    description?: string;
  }

  const BATCH = VIDEO_PAGE_LOAD_MORE;
  let allVideos: VideoItem[] | null = null;
  let loaded = 0;

  function escapeHtml(value: string): string {
    return value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function fmtDate(d: string): string {
    try {
      return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    } catch {
      return d;
    }
  }

  function renderRow(video: VideoItem, base: string): string {
    const safeTitle = escapeHtml(video.title);
    const thumbUrl = `https://i.ytimg.com/vi/${video.youtubeId}/hqdefault.jpg`;
    const tags = (video.tags ?? []).slice(0, 4).map(escapeHtml).join(' · ');
    const date = escapeHtml(fmtDate(video.pubDate));
    const desc = video.description ? escapeHtml(video.description) : '';

    return `<a href="${base}videos/${video.youtubeId}" class="video-row" data-youtube-id="${video.youtubeId}">
      <div class="video-row-thumb">
        <img src="${thumbUrl}" alt="${safeTitle}" loading="lazy" decoding="async" width="320" height="180">
        <div class="video-row-play" aria-hidden="true">▶</div>
      </div>
      <div class="video-row-body">
        <div class="video-row-title">${safeTitle}</div>
        <div class="video-row-meta">
          <span class="video-row-date">${date}</span>
          ${tags ? `<span class="video-row-sep">·</span><span class="video-row-tags">${tags}</span>` : ''}
        </div>
        ${desc ? `<div class="video-row-desc">${desc}</div>` : ''}
      </div>
    </a>`;
  }

  async function fetchVideos(): Promise<VideoItem[]> {
    if (allVideos) return allVideos;
    const list = document.getElementById('videos-list');
    const base = list?.dataset.base || '/';
    const res = await fetch(`${base}videos/api/video-cards.json`);
    allVideos = await res.json() as VideoItem[];
    return allVideos;
  }

  function appendRows(videos: VideoItem[], base: string) {
    const list = document.getElementById('videos-list');
    if (!list) return;
    videos.forEach(video => {
      list.insertAdjacentHTML('beforeend', renderRow(video, base));
    });
  }

  function bindLoadMore() {
    const btn = document.getElementById('load-more-videos-btn');
    const list = document.getElementById('videos-list');
    if (!btn || !list) return;

    loaded = list.children.length;

    btn.addEventListener('click', async () => {
      const videos = await fetchVideos();
      const base = list.dataset.base || '/';
      const remaining = videos.slice(loaded, loaded + BATCH);

      if (remaining.length === 0) {
        btn.remove();
        return;
      }

      appendRows(remaining, base);
      loaded += remaining.length;

      if (loaded >= videos.length) {
        btn.remove();
      }
    });
  }

  document.addEventListener('astro:page-load', bindLoadMore);
  bindLoadMore();
</script>

<style is:global>
  .video-list {
    display: flex;
    flex-direction: column;
  }

  .video-row {
    display: flex;
    gap: 1rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--theme-border);
    text-decoration: none;
    color: inherit;
    transition: background-color 0.15s ease;
  }

  .video-row:hover {
    background-color: var(--theme-bg-hover);
  }

  .video-row:last-child {
    border-bottom: none;
  }

  .video-row-thumb {
    position: relative;
    flex: 0 0 240px;
    aspect-ratio: 16 / 9;
    background-color: var(--theme-bg-elevated);
    overflow: hidden;
    border: 1px solid var(--theme-border);
  }

  .video-row-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video-row-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.35);
    color: #fff;
    font-size: 2rem;
    opacity: 0;
    transition: opacity 0.15s ease;
    pointer-events: none;
  }

  .video-row:hover .video-row-play {
    opacity: 1;
  }

  .video-row-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-top: 0.125rem;
  }

  .video-row-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--theme-text-primary);
    line-height: 1.3;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .video-row:hover .video-row-title {
    color: var(--theme-accent);
  }

  .video-row-meta {
    font-size: 0.75rem;
    color: var(--theme-text-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .video-row-sep {
    opacity: 0.5;
  }

  .video-row-desc {
    font-size: 0.8125rem;
    color: var(--theme-text-secondary);
    line-height: 1.45;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    margin-top: 0.125rem;
  }

  /* Mobile: stack vertically */
  @media (max-width: 640px) {
    .video-row {
      flex-direction: column;
      gap: 0.625rem;
    }
    .video-row-thumb {
      flex: 0 0 auto;
      width: 100%;
    }
  }
</style>
