---
import Layout from '../../layouts/Layout.astro';
import { getVideo, getAllVideos } from '../../lib/videos';

export async function getStaticPaths() {
  const videos = getAllVideos();
  return videos.map((video) => ({
    params: { slug: video.youtubeId },
    props: { video },
  }));
}

interface Props {
  video: Awaited<ReturnType<typeof getAllVideos>>[number];
}

const { video } = Astro.props;

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
---

<Layout title={video.title}>
  <div class="video-page theme-surface" data-post-slug={video.youtubeId}>
    <!-- YouTube embed (responsive 16:9) -->
    <div class="video-embed-wrapper">
      <iframe
        src={`https://www.youtube.com/embed/${video.youtubeId}?rel=0`}
        title={video.title}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>

    <!-- Video metadata -->
    <div class="video-meta theme-border">
      <h1 class="text-xl font-bold theme-text-primary">{video.title}</h1>
    </div>

    <!-- Optional description/review text -->
    {video.description && (
      <div
        class="video-description prose theme-text-secondary mt-4 markdown-content"
        data-original-html={video.description.split('\n').map(p => `<p>${p}</p>`).join('\n')}
      >
        {video.description.split('\n').map(p => <p>{p}</p>)}
      </div>
    )}

    <!-- Back to videos list -->
    <div class="mt-6">
      <a href={`${base}videos`} class="text-sm theme-text-accent">&larr; back to all videos</a>
    </div>
  </div>
</Layout>

<script>
  import { getCurrentSiteLang, SITE_LANGS } from '../../lib/site-i18n.mjs';
  import { applyTranslationToElement, setupTranslationListener } from '../../lib/translation.mjs';

  function initVideoTranslation() {
    const content = document.querySelector('.markdown-content');
    const slug = content?.closest('[data-post-slug]')?.getAttribute('data-post-slug');
    if (content && slug) {
      const lang = getCurrentSiteLang();
      if (lang !== 'ru') applyTranslationToElement(content, slug, { type: 'videos' });
    }
  }

  setupTranslationListener(() => {
    const content = document.querySelector('.markdown-content');
    return content?.closest('[data-post-slug]')?.getAttribute('data-post-slug') || null;
  });

  document.addEventListener('astro:page-load', initVideoTranslation);
  initVideoTranslation();
</script>

<style is:global>
  .video-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 1.5rem;
  }
  .video-embed-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin-bottom: 1.5rem;
    border: 1px solid var(--theme-border);
    overflow: hidden;
  }
  .video-embed-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
  .video-meta {
    border-bottom: 1px solid var(--theme-border);
    padding-bottom: 1rem;
  }
  .tag-chip {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    margin-right: 0.5rem;
    font-size: 0.75rem;
    border-radius: 0.25rem;
    color: var(--theme-text-muted);
  }

  .lang-fallback-banner {
    padding: 8px 12px;
    margin-bottom: 12px;
    font-size: 12px;
    border: 1px dashed var(--theme-border);
    color: var(--theme-text-muted);
  }

  .markdown-content.is-translating {
    opacity: 0.5;
  }
</style>
