---
import Layout from '../../layouts/Layout.astro';
import { getVideo, getAllVideos } from '../../lib/videos';

export async function getStaticPaths() {
  const videos = getAllVideos();
  return videos.map((video) => ({
    params: { slug: video.youtubeId },
    props: { video },
  }));
}

interface Props {
  video: Awaited<ReturnType<typeof getAllVideos>>[number];
}

const { video } = Astro.props;

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
---

<Layout title={video.title}>
  <div class="video-page theme-surface" data-post-slug={video.youtubeId}>
    <!-- YouTube embed (responsive 16:9) -->
    <div class="video-embed-wrapper">
      <iframe
        src={`https://www.youtube.com/embed/${video.youtubeId}?rel=0`}
        title={video.title}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>

    <!-- Video metadata -->
    <div class="video-meta theme-border">
      <h1 class="video-title text-xl font-bold theme-text-primary" data-orig-title={video.title}>{video.title}</h1>
    </div>

    <!-- Optional description/review text -->
    <div
      class="video-description prose theme-text-secondary mt-4 markdown-content"
      data-orig-desc={video.description || ''}
      data-original-html={(video.description || '').split('\n').map(p => `<p>${p}</p>`).join('\n')}
      style={!video.description ? 'display:none' : ''}
    >
      {(video.description || '').split('\n').map(p => <p>{p}</p>)}
    </div>

    <!-- Back to videos list -->
    <div class="mt-6">
      <a href={`${base}videos`} class="text-sm theme-text-accent">&larr; back to all videos</a>
    </div>
  </div>
</Layout>

<script>
  import { fetchTitledTranslation, getCurrentSiteLang } from '../../lib/translation.mjs';

  function renderDescriptionHtml(text: string): string {
    return text
      .trim()
      .split(/\n\s*\n/)
      .filter((p) => p.trim())
      .map((p) => `<p>${p.trim().replace(/\n/g, '<br>')}</p>`)
      .join('\n');
  }

  async function applyVideoTranslation() {
    const root = document.querySelector<HTMLElement>('[data-post-slug]');
    if (!root) return;
    const slug = root.dataset.postSlug || '';
    const titleEl = root.querySelector<HTMLElement>('.video-title');
    const descEl = root.querySelector<HTMLElement>('.markdown-content');
    if (!titleEl) return;

    const lang = getCurrentSiteLang();
    const origTitle = titleEl.dataset.origTitle || titleEl.textContent || '';
    const origDesc = descEl?.dataset.origDesc || '';

    if (lang === 'ru') {
      titleEl.textContent = origTitle;
      if (descEl) {
        if (origDesc) {
          descEl.style.display = '';
          descEl.innerHTML = renderDescriptionHtml(origDesc);
        } else {
          descEl.style.display = 'none';
        }
      }
      return;
    }

    const parsed = await fetchTitledTranslation(slug, 'videos', lang);
    if (!parsed) {
      // No translation available — fall back to original
      titleEl.textContent = origTitle;
      if (descEl) {
        if (origDesc) {
          descEl.style.display = '';
          descEl.innerHTML = renderDescriptionHtml(origDesc);
        } else {
          descEl.style.display = 'none';
        }
      }
      return;
    }

    titleEl.textContent = parsed.title || origTitle;
    if (descEl) {
      if (parsed.description) {
        descEl.style.display = '';
        descEl.innerHTML = renderDescriptionHtml(parsed.description);
      } else {
        descEl.style.display = 'none';
      }
    }
  }

  document.addEventListener('astro:page-load', applyVideoTranslation);
  document.addEventListener('lang-changed', applyVideoTranslation);
  applyVideoTranslation();
</script>

<style is:global>
  .video-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 1.5rem;
  }
  .video-embed-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin-bottom: 1.5rem;
    border: 1px solid var(--theme-border);
    overflow: hidden;
  }
  .video-embed-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
  .video-meta {
    border-bottom: 1px solid var(--theme-border);
    padding-bottom: 1rem;
  }
  .tag-chip {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    margin-right: 0.5rem;
    font-size: 0.75rem;
    border-radius: 0.25rem;
    color: var(--theme-text-muted);
  }

  .lang-fallback-banner {
    padding: 8px 12px;
    margin-bottom: 12px;
    font-size: 12px;
    border: 1px dashed var(--theme-border);
    color: var(--theme-text-muted);
  }

  .markdown-content.is-translating {
    opacity: 0.5;
  }
</style>
