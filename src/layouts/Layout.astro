---
import { ViewTransitions } from 'astro:transitions';
import './layout.css';
import '../styles/global.css';
import '../styles/themes.css';
import SideMenu from '../components/Side/SideMenu.astro';
import FloatingPlayerDock from '../components/FloatingPlayerDock.astro';
import {
  getPublishedPostCount,
  getRecentPosts,
} from '../lib/blog-data.mjs';
import { SIDEBAR_INITIAL_POSTS } from '../lib/feed-limits.mjs';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
}

const {
  title = 'poeba.lu',
  description = 'music reviews',
  image,
  type = 'website',
} = Astro.props;

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://poeba.lu';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = image || `${siteUrl}${base}og-default.png`;
const fullTitle = `${title} | poeba.lu`;

const [recentPosts, totalPosts] = await Promise.all([
  getRecentPosts(SIDEBAR_INITIAL_POSTS),
  getPublishedPostCount(),
]);
const hasMoreRecentPosts = totalPosts > SIDEBAR_INITIAL_POSTS;
const lightThemeIds = [
  'light',
  'nord-light',
  'catppuccin-latte',
  'rose-pine-dawn',
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href={`${base}favicon-32x32.png`}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href={`${base}favicon-16x16.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href={`${base}apple-touch-icon.png`}
    />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="base-url" content={base} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="poeba.lu" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Telegram -->
    <meta name="telegram:channel" content="@hellomraz" />
    <link rel="preconnect" href="https://f4.bcbits.com" crossorigin />
    <link rel="dns-prefetch" href="https://f4.bcbits.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <ViewTransitions fallback="swap" />
    <!-- Apply saved theme before first paint to prevent flash -->
    <script is:inline define:vars={{ lightThemeIds }}>
      (function () {
        var lightThemes = new Set(lightThemeIds || []);
        window.__hellomrazApplyTheme = function (nextTheme) {
          var theme = nextTheme || localStorage.getItem('color-theme') || 'dark';
          var html = document.documentElement;
          html.setAttribute('data-theme', theme);
          if (lightThemes.has(theme)) {
            html.classList.remove('dark');
          } else {
            html.classList.add('dark');
          }
        };

        document.documentElement.classList.add('no-transition');
        window.__hellomrazApplyTheme();
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            document.documentElement.classList.remove('no-transition');
          });
        });
      })();
    </script>
    <!-- Umami Analytics -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="c50bec21-a36c-4762-92ce-7335a35a4060"></script>
  </head>
  <body>
    <div class="app-shell flex items-stretch overflow-hidden theme-base">
      <!-- Mobile sidebar overlay -->
      <div
        id="mobile-sidebar-overlay"
        class="mobile-sidebar-overlay"
        aria-hidden="true"
      >
        <div class="mobile-sidebar-backdrop"></div>
        <div class="mobile-sidebar-panel">
          <div class="mobile-sidebar-header">
            <button
              id="mobile-sidebar-close"
              class="mobile-sidebar-close"
              aria-label="Close menu">✕</button
            >
          </div>
          <div class="mobile-sidebar-content">
            <SideMenu initialPosts={recentPosts} hasMore={hasMoreRecentPosts} />
          </div>
        </div>
      </div>

      <!-- Sidebar — hidden on small screens -->
      <div
        class="w-[280px] flex-col hidden lg:flex overflow-y-auto flex-shrink-0 border-r theme-border"
        transition:persist="sidebar"
      >
        <SideMenu initialPosts={recentPosts} hasMore={hasMoreRecentPosts} />
      </div>
      <!-- Main content -->
      <div class="flex-1 overflow-y-auto overflow-x-hidden theme-surface">
        <slot />
      </div>
    </div>

    <FloatingPlayerDock />

    <!-- View-transitions support warning -->
    <div
      id="not-support"
      class="fixed hidden bg-amber-700 bottom-0 inset-x-0 rounded-t-md text-center py-2 z-50 font-semibold text-sm"
    >
      Your browser doesn't support View Transitions yet — try Chrome or Edge.
    </div>

    <script>
      import { navigate } from 'astro:transitions/client';

      type LayoutWindow = Window & {
        __hellomrazApplyTheme?: (theme?: string | null) => void;
        __hellomrazNavigate?: (href: string) => Promise<void> | void;
        __themePersistenceBound?: boolean;
      };

      const layoutWindow = window as LayoutWindow;

      function applySavedTheme() {
        const applyTheme = layoutWindow.__hellomrazApplyTheme;
        if (typeof applyTheme === 'function') {
          applyTheme();
          return;
        }

        const fallbackTheme = localStorage.getItem('color-theme') || 'dark';
        document.documentElement.setAttribute('data-theme', fallbackTheme);
      }

      if (!layoutWindow.__hellomrazNavigate) {
        layoutWindow.__hellomrazNavigate = async (href: string) => {
          if (!href) return;

          try {
            await navigate(href);
          } catch {
            window.location.assign(href);
          }
        };
      }

      if (!layoutWindow.__themePersistenceBound) {
        layoutWindow.__themePersistenceBound = true;
        document.addEventListener('astro:after-swap', applySavedTheme);
        document.addEventListener('astro:page-load', applySavedTheme);
      }

      applySavedTheme();
    </script>

    <script>
      type LayoutUiWindow = Window & {
        __layoutUiBound?: boolean;
      };

      function revealFadeTargets() {
        for (const el of document.querySelectorAll('.el-to-fade')) {
          el.classList.remove('scale-90');
        }
      }

      if (!document.startViewTransition) {
        const el = document.getElementById('not-support');
        if (el) el.classList.remove('hidden');
      }

      if (!(window as LayoutUiWindow).__layoutUiBound) {
        (window as LayoutUiWindow).__layoutUiBound = true;
        document.addEventListener('astro:page-load', revealFadeTargets);
      }

      revealFadeTargets();
    </script>

    <!-- Mobile sidebar toggle -->
    <script>
      type MobileSidebarWindow = Window & {
        __mobileSidebarKeydownBound?: boolean;
        __mobileSidebarInitBound?: boolean;
      };

      function closeMobileSidebar() {
        const overlay = document.getElementById('mobile-sidebar-overlay');
        if (!overlay) return;

        overlay.classList.remove('open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      function initMobileSidebar() {
        const overlay = document.getElementById('mobile-sidebar-overlay');
        if (!overlay) return;

        function open() {
          overlay.classList.add('open');
          overlay.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        }

        // Always re-bind: the button may be persisted but overlay is fresh
        const openBtn = document.getElementById('mobile-menu-btn');
        const closeBtn = document.getElementById('mobile-sidebar-close');
        const backdrop = overlay.querySelector('.mobile-sidebar-backdrop');

        if (openBtn) {
          openBtn.onclick = open;
        }
        if (closeBtn) closeBtn.onclick = closeMobileSidebar;
        if (backdrop) (backdrop as HTMLElement).onclick = closeMobileSidebar;

        if (!(window as MobileSidebarWindow).__mobileSidebarKeydownBound) {
          (window as MobileSidebarWindow).__mobileSidebarKeydownBound = true;
          document.addEventListener('keydown', (event) => {
            const currentOverlay = document.getElementById('mobile-sidebar-overlay');
            if (
              event.key === 'Escape' &&
              currentOverlay?.classList.contains('open')
            ) {
              closeMobileSidebar();
            }
          });
        }

        // Close on navigation (view transitions)
        closeMobileSidebar();
      }

      if (!(window as MobileSidebarWindow).__mobileSidebarInitBound) {
        (window as MobileSidebarWindow).__mobileSidebarInitBound = true;
        document.addEventListener('astro:page-load', initMobileSidebar);
      }
      initMobileSidebar();
    </script>
  </body>
</html>
