---
import { ViewTransitions } from "astro:transitions";
import "./layout.css";
import "../styles/global.css";
import "../styles/themes.css";
import SideMenu from "../components/Side/SideMenu.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
}

const {
  title = "poeba.lu",
  description = "music reviews",
  image,
  type = "website",
} = Astro.props;

const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
const siteUrl = Astro.site?.toString().replace(/\/$/, "") || "https://poeba.lu";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = image || `${siteUrl}${base}og-default.png`;
const fullTitle = `${title} | poeba.lu`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32x32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${base}favicon-16x16.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}apple-touch-icon.png`} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="base-url" content={base} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="poeba.lu" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Telegram -->
    <meta name="telegram:channel" content="@hellomraz" />
    <link rel="preconnect" href="https://f4.bcbits.com" crossorigin />
    <link rel="dns-prefetch" href="https://f4.bcbits.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <ViewTransitions fallback="none" />
    <!-- Apply saved theme before first paint to prevent flash -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('color-theme') || 'dark';
        document.documentElement.setAttribute('data-theme', t);
        document.documentElement.classList.add('no-transition');
        if (t === 'light' || t === 'nord-light' || t === 'catppuccin-latte') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            document.documentElement.classList.remove('no-transition');
          });
        });
      })();
    </script>
  </head>
  <body>
    <div class="app-shell flex items-stretch overflow-hidden" style="background-color: var(--theme-bg-base);">
      <!-- Mobile sidebar overlay -->
      <div id="mobile-sidebar-overlay" class="mobile-sidebar-overlay" aria-hidden="true">
        <div class="mobile-sidebar-backdrop"></div>
        <div class="mobile-sidebar-panel">
          <div class="mobile-sidebar-header">
            <button id="mobile-sidebar-close" class="mobile-sidebar-close" aria-label="Close menu">✕</button>
          </div>
          <div class="mobile-sidebar-content">
            <SideMenu />
          </div>
        </div>
      </div>

      <!-- Sidebar — hidden on small screens -->
      <div class="w-[280px] flex-col hidden lg:flex overflow-y-auto flex-shrink-0 border-r" style="border-color: var(--theme-border);" transition:persist="sidebar">
        <SideMenu />
      </div>
      <!-- Main content -->
      <div class="flex-1 overflow-y-auto overflow-x-hidden" style="background-color: var(--theme-bg-surface);">
        <slot />
      </div>
    </div>

    <!-- View-transitions support warning -->
    <div
      id="not-support"
      class="fixed hidden bg-amber-700 bottom-0 inset-x-0 rounded-t-md text-center py-2 z-50 font-semibold text-sm"
    >
      Your browser doesn't support View Transitions yet — try Chrome or Edge.
    </div>

    <script>
      if (!document.startViewTransition) {
        const el = document.getElementById("not-support");
        if (el) el.classList.remove("hidden");
      }
      document.addEventListener("astro:page-load", () => {
        for (const el of document.querySelectorAll(".el-to-fade")) {
          el.classList.remove("scale-90");
        }
      });
    </script>

    <!-- Mobile sidebar toggle -->
    <script>
      function initMobileSidebar() {
        const overlay = document.getElementById('mobile-sidebar-overlay');
        if (!overlay) return;

        function open() {
          overlay.classList.add('open');
          overlay.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        }
        function close() {
          overlay.classList.remove('open');
          overlay.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        }

        // Always re-bind: the button may be persisted but overlay is fresh
        const openBtn = document.getElementById('mobile-menu-btn');
        const closeBtn = document.getElementById('mobile-sidebar-close');
        const backdrop = overlay.querySelector('.mobile-sidebar-backdrop');

        if (openBtn) {
          // Remove previous handler to avoid duplicates on persist
          openBtn.onclick = open;
        }
        if (closeBtn) closeBtn.onclick = close;
        if (backdrop) (backdrop as HTMLElement).onclick = close;

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && overlay.classList.contains('open')) close();
        });

        // Close on navigation (view transitions)
        close();
      }
      document.addEventListener('astro:page-load', initMobileSidebar);
      initMobileSidebar();
    </script>
  </body>
</html>
