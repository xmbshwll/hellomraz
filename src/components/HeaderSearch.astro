---
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
---

<div id="header-search" class="header-search" data-base={base}>
  <form class="header-search-form" role="search" autocomplete="off">
    <label class="header-search-sr-only" for="header-search-input">
      Search artist or album
    </label>
    <div class="header-search-field">
      <span class="header-search-icon" aria-hidden="true">⌕</span>
      <input
        id="header-search-input"
        class="header-search-input"
        type="search"
        placeholder="search artist / album"
        autocomplete="off"
        spellcheck="false"
        enterkeyhint="search"
      />
      <button
        id="header-search-clear"
        class="header-search-clear"
        type="button"
        aria-label="Clear search"
        hidden
      >
        ✕
      </button>
    </div>
  </form>

  <div id="header-search-results" class="header-search-results" hidden></div>
</div>

<script>
  import { createFloatingDropdown } from "../lib/floating-dropdown.mjs";
  import {
    getSearchResultPrimaryLabel,
    getSearchResultSecondaryLabel,
    prepareSearchEntries,
    searchEntries,
  } from "../lib/search.mjs";

  interface SearchRawEntry {
    slug: string;
    title: string;
    artist?: string;
    album?: string;
  }

  interface PreparedSearchEntry extends SearchRawEntry {
    order: number;
    titleSearch: string;
    artistSearch: string;
    albumSearch: string;
    searchText: string;
  }

  let cachedBase = "";
  let cachedEntries: PreparedSearchEntry[] | null = null;
  let loadingPromise: Promise<PreparedSearchEntry[]> | null = null;

  async function loadSearchIndex(base: string): Promise<PreparedSearchEntry[]> {
    if (cachedEntries && cachedBase === base) return cachedEntries;

    if (!loadingPromise || cachedBase !== base) {
      cachedBase = base;
      loadingPromise = fetch(`${base}api/search.json`)
        .then(async (response) => {
          if (!response.ok) {
            throw new Error("Failed to load search index");
          }
          const raw = (await response.json()) as SearchRawEntry[];
          cachedEntries = prepareSearchEntries(raw) as PreparedSearchEntry[];
          return cachedEntries;
        })
        .catch(() => {
          cachedEntries = [];
          return [];
        });
    }

    return loadingPromise;
  }

  function renderMessage(
    resultsEl: HTMLElement,
    message: string,
    kind = "info",
  ) {
    resultsEl.innerHTML = "";

    const empty = document.createElement("div");
    empty.className = `header-search-message ${kind === "loading" ? "is-loading" : ""}`;
    empty.textContent = message;
    resultsEl.appendChild(empty);
  }

  function renderResults(
    resultsEl: HTMLElement,
    matches: SearchRawEntry[],
    base: string,
    query: string,
  ) {
    resultsEl.innerHTML = "";

    if (!matches.length) {
      renderMessage(resultsEl, `no albums for “${query.trim()}”`);
      return;
    }

    const list = document.createElement("div");
    list.className = "header-search-list";

    for (const entry of matches) {
      const link = document.createElement("a");
      link.className = "header-search-result";
      link.href = `${base}blog/${entry.slug}`;

      const title = document.createElement("span");
      title.className = "header-search-result-title";
      title.textContent = getSearchResultPrimaryLabel(entry);
      link.appendChild(title);

      const secondary = getSearchResultSecondaryLabel(entry);
      if (secondary) {
        const meta = document.createElement("span");
        meta.className = "header-search-result-meta";
        meta.textContent = secondary;
        link.appendChild(meta);
      }

      list.appendChild(link);
    }

    resultsEl.appendChild(list);
  }

  function bindHeaderSearch() {
    const root = document.getElementById("header-search") as HTMLElement | null;
    if (!root || (root as any).__headerSearchBound) return;

    const form = root.querySelector(
      ".header-search-form",
    ) as HTMLFormElement | null;
    const fieldEl = root.querySelector(
      ".header-search-field",
    ) as HTMLElement | null;
    const input = root.querySelector(
      ".header-search-input",
    ) as HTMLInputElement | null;
    const clearBtn = root.querySelector(
      ".header-search-clear",
    ) as HTMLButtonElement | null;
    const resultsEl = root.querySelector(
      ".header-search-results",
    ) as HTMLElement | null;

    if (!form || !fieldEl || !input || !clearBtn || !resultsEl) return;

    (root as any).__headerSearchBound = true;

    const base = root.dataset.base || "/";
    let requestId = 0;

    const floatingSearchResults = createFloatingDropdown({
      getAnchor: () => fieldEl,
      getPanel: () => resultsEl,
      zIndex: 99999,
      position: {
        align: "start",
        width: (anchorRect) => Math.max(220, anchorRect.width),
        offset: 6,
        viewportPadding: 4,
        maxHeight: 352,
        minHeight: 120,
        flipThreshold: 160,
      },
      setPanelOpen(panel, open) {
        panel.hidden = !open;
        panel.style.opacity = open ? "1" : "0";
        panel.style.pointerEvents = open ? "auto" : "none";
      },
      onOpenChange(open) {
        root.classList.toggle("is-open", open);
      },
    });

    function resetResults() {
      resultsEl.innerHTML = "";
      floatingSearchResults.close();
    }

    function syncClearButton() {
      clearBtn.hidden = input.value.length === 0;
    }

    async function findMatches(query: string) {
      const trimmed = query.trim();
      if (!trimmed) return [];
      const entries = await loadSearchIndex(base);
      return searchEntries(entries, trimmed, 8) as PreparedSearchEntry[];
    }

    async function updateResults(query: string) {
      const currentRequest = ++requestId;
      const trimmed = query.trim();
      syncClearButton();

      if (!trimmed) {
        resetResults();
        return [] as PreparedSearchEntry[];
      }

      if (!cachedEntries) {
        renderMessage(resultsEl, "searching…", "loading");
        floatingSearchResults.open();
      }

      const matches = await findMatches(trimmed);
      if (currentRequest !== requestId) return [] as PreparedSearchEntry[];

      renderResults(resultsEl, matches, base, trimmed);
      floatingSearchResults.open();
      return matches;
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const matches = await findMatches(input.value);
      const first = matches[0];
      if (first) {
        window.location.href = `${base}blog/${first.slug}`;
      } else if (input.value.trim()) {
        renderResults(resultsEl, [], base, input.value);
        floatingSearchResults.open();
      }
    });

    input.addEventListener("focus", () => {
      if (!cachedEntries) {
        void loadSearchIndex(base);
      }
      if (input.value.trim()) {
        void updateResults(input.value);
      }
    });

    input.addEventListener("input", () => {
      void updateResults(input.value);
    });

    input.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        resetResults();
        input.blur();
      }
    });

    clearBtn.addEventListener("click", () => {
      input.value = "";
      syncClearButton();
      resetResults();
      input.focus();
    });

    document.addEventListener("astro:page-load", () => {
      input.value = "";
      syncClearButton();
      resetResults();
    });

    syncClearButton();
  }

  document.addEventListener("astro:page-load", bindHeaderSearch);
  bindHeaderSearch();
</script>

<style>
  .header-search {
    position: relative;
    z-index: 9999;
    isolation: isolate;
    flex: 1 1 18rem;
    min-width: min(100%, 14rem);
    max-width: 26rem;
  }
  .header-search-form {
    margin: 0;
  }
  .header-search-field {
    position: relative;
    display: flex;
    align-items: center;
  }
  .header-search-icon {
    position: absolute;
    left: 0.75rem;
    color: var(--theme-text-muted);
    pointer-events: none;
    font-size: 0.875rem;
  }
  .header-search-input {
    width: 100%;
    min-height: 44px;
    padding: 0.625rem 2.5rem 0.625rem 2rem;
    border: 1px solid var(--theme-border);
    border-radius: 0.375rem;
    background: var(--theme-bg-elevated);
    color: var(--theme-text-primary);
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.15s;
  }
  .header-search-input::placeholder {
    color: var(--theme-text-muted);
  }
  .header-search-input:hover,
  .header-search-input:focus,
  .header-search.is-open .header-search-input {
    border-color: var(--theme-accent);
  }
  .header-search-input:focus {
    box-shadow: 0 0 0 2px
      color-mix(in srgb, var(--theme-accent) 25%, transparent);
  }
  .header-search-clear {
    position: absolute;
    right: 0.375rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    border-radius: 9999px;
    background: transparent;
    color: var(--theme-text-muted);
    cursor: pointer;
    transition:
      color 0.15s,
      background 0.15s;
  }
  .header-search-clear:hover {
    color: var(--theme-text-primary);
    background: var(--theme-bg-hover);
  }
  .header-search-results {
    position: fixed;
    top: 0;
    left: 0;
    width: min(26rem, calc(100vw - 0.5rem));
    max-height: 22rem;
    overflow-y: auto;
    border: 1px solid var(--theme-border);
    border-radius: 0.5rem;
    background: var(--theme-bg-surface);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.25);
    z-index: 99999;
  }
  .header-search-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 640px) {
    .header-search {
      flex-basis: 100%;
      max-width: none;
    }
  }
</style>

<style is:global>
  .header-search-list {
    display: flex;
    flex-direction: column;
  }
  .header-search-result {
    display: flex;
    flex-direction: column;
    gap: 0.1875rem;
    padding: 0.75rem 0.875rem;
    min-height: 44px;
    text-decoration: none;
    color: var(--theme-text-secondary);
    border-top: 1px solid var(--theme-border);
    transition:
      background 0.15s,
      color 0.15s;
  }
  .header-search-result:first-child {
    border-top: none;
  }
  .header-search-result:hover,
  .header-search-result:focus-visible {
    background: var(--theme-bg-hover);
    color: var(--theme-text-primary);
    outline: none;
  }
  .header-search-result-title {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: inherit;
  }
  .header-search-result-meta {
    display: block;
    font-size: 0.75rem;
    color: var(--theme-text-muted);
  }
  .header-search-message {
    display: block;
    padding: 0.875rem;
    font-size: 0.8125rem;
    color: var(--theme-text-muted);
  }
  .header-search-message.is-loading {
    color: var(--theme-text-secondary);
  }
</style>
