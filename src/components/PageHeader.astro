---
import '../styles/selectable-dropdown.css';
import DateSelector from './DateSelector.astro';
import HeaderSearch from './HeaderSearch.astro';
import LangSwitcher from './LangSwitcher.astro';
import ThemeChooser from './ThemeChooser.astro';
import {
  BUY_ME_A_COFFEE_LINK,
  RSS_LINK,
  TELEGRAM_LINK,
  getSiteLinkHref,
} from '../lib/site-links';

interface Props {
  dateIndex: Record<string, number>;
  currentYear?: number;
  currentMonth?: number;
}

const { dateIndex, currentYear, currentMonth } = Astro.props;
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const buyMeACoffeeHref = getSiteLinkHref(BUY_ME_A_COFFEE_LINK, base);
const rssHref = getSiteLinkHref(RSS_LINK, base);
const telegramHref = getSiteLinkHref(TELEGRAM_LINK, base);
---

<div class="page-header" transition:name="page-header" transition:persist>
  <div class="header-left">
    <button
      id="mobile-menu-btn"
      class="header-control-btn mobile-menu-btn"
      aria-label="Open menu"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        viewBox="0 0 20 20"
        fill="currentColor"
      >
        <path
          fill-rule="evenodd"
          d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z"
          clip-rule="evenodd"
        ></path>
      </svg>
    </button>
    <HeaderSearch />
    <DateSelector
      dateIndex={dateIndex}
      baseUrl={`${base}blog`}
      currentYear={currentYear}
      currentMonth={currentMonth}
    />
  </div>

  <div class="header-actions">
    <a
      target="_blank"
      rel="noopener noreferrer"
      href={buyMeACoffeeHref}
      class="header-control-btn"
    >
      <span class="bmc-icon">☕</span>
      <span class="bmc-label">{BUY_ME_A_COFFEE_LINK.value}</span>
    </a>
    <ThemeChooser />
    <LangSwitcher />
    <a
      aria-label={RSS_LINK.ariaLabel}
      title={RSS_LINK.title}
      href={rssHref}
      type="application/rss+xml"
      class="header-icon-link"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path d="M6.18 17.82a1.64 1.64 0 1 1 0 3.28 1.64 1.64 0 0 1 0-3.28ZM3 10.18v3.27A7.55 7.55 0 0 1 10.55 21h3.27C13.82 14.84 9.16 10.18 3 10.18Zm0-7.28v3.27C12.96 6.17 17.83 11.04 17.83 21h3.27C21.1 9.24 14.76 2.9 3 2.9Z"></path>
      </svg>
    </a>
    <a
      target="_blank"
      rel="noopener noreferrer"
      aria-label={TELEGRAM_LINK.ariaLabel}
      title={TELEGRAM_LINK.title}
      href={telegramHref}
      class="header-icon-link"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path
          d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
        ></path>
      </svg>
    </a>
    <button
      type="button"
      class="header-icon-link pwa-install-btn"
      aria-label="Install app"
      title="Install app"
      data-pwa-install-btn
      hidden
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 3v10"></path>
        <path d="m8 9 4 4 4-4"></path>
        <path d="M5 21h14"></path>
      </svg>
    </button>
  </div>
</div>

<style>
  .page-header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid var(--theme-border);
    background-color: var(--theme-bg-surface);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .header-actions > * + * {
    position: relative;
  }

  .header-actions > * + *::before {
    content: '│';
    position: absolute;
    left: -0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--theme-border);
    pointer-events: none;
  }

  .header-icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    color: var(--theme-text-muted);
    transition: color 0.15s;
  }

  .header-icon-link:hover {
    color: var(--theme-accent);
  }

  .pwa-install-btn {
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  .mobile-menu-btn {
    width: 44px;
    padding: 0;
    justify-content: center;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .page-header {
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
      padding: 0.5rem 0.75rem;
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .header-actions {
      justify-content: flex-start;
      gap: 0.5rem;
    }

    .header-actions > * + *::before {
      display: none;
    }

    .bmc-label,
    .pwa-install-btn {
      display: none;
    }
  }

  @media (min-width: 641px) {
    .header-left {
      flex: 1;
      min-width: 0;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
  }

  @media (min-width: 1024px) {
    .mobile-menu-btn {
      display: none;
    }
  }
</style>

<script>
  interface BeforeInstallPromptEvent extends Event {
    prompt(): Promise<void>;
    userChoice: Promise<{
      outcome: 'accepted' | 'dismissed';
      platform: string;
    }>;
  }

  type PwaWindow = Window & {
    __deferredPwaPrompt?: BeforeInstallPromptEvent | null;
    __pwaInstallButtonBound?: boolean;
  };

  const pwaWindow = window as PwaWindow;

  function isStandalone() {
    return (
      window.matchMedia('(display-mode: standalone)').matches ||
      (window.navigator as Navigator & { standalone?: boolean }).standalone === true
    );
  }

  function syncInstallButtons() {
    const canInstall = !isStandalone() && !!pwaWindow.__deferredPwaPrompt;

    document
      .querySelectorAll<HTMLButtonElement>('[data-pwa-install-btn]')
      .forEach((button) => {
        button.hidden = !canInstall;
      });
  }

  function bindInstallButtons() {
    document
      .querySelectorAll<HTMLButtonElement>('[data-pwa-install-btn]')
      .forEach((button) => {
        if (button.dataset.pwaInstallBound === 'true') return;
        button.dataset.pwaInstallBound = 'true';

        button.addEventListener('click', async () => {
          const promptEvent = pwaWindow.__deferredPwaPrompt;
          if (!promptEvent) return;

          pwaWindow.__deferredPwaPrompt = null;
          syncInstallButtons();

          await promptEvent.prompt();
          await promptEvent.userChoice.catch(() => undefined);
          syncInstallButtons();
        });
      });
  }

  function initPwaInstallButtons() {
    bindInstallButtons();
    syncInstallButtons();
  }

  if (!pwaWindow.__pwaInstallButtonBound) {
    pwaWindow.__pwaInstallButtonBound = true;
    document.addEventListener('astro:page-load', initPwaInstallButtons);
    window.addEventListener('pwa-install-available', syncInstallButtons);
    window.addEventListener('pwa-installed', syncInstallButtons);
  }

  initPwaInstallButtons();
</script>
