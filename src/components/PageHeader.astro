---
import '../styles/selectable-dropdown.css';
import ThemeChooser from './ThemeChooser.astro';
import LangSwitcher from './LangSwitcher.astro';
import HeaderSearch from './HeaderSearch.astro';
import DateSelector from './DateSelector.astro';

interface Props {
  dateIndex: Record<string, number>;
  currentYear?: number;
  currentMonth?: number;
}

const { dateIndex, currentYear, currentMonth } = Astro.props;
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
---

<div class="page-header" transition:name="page-header" transition:persist>
  <!-- Left: Hamburger (mobile) + Search + Date picker -->
  <div class="header-left">
    <button id="mobile-menu-btn" class="mobile-menu-btn" aria-label="Open menu">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        viewBox="0 0 20 20"
        fill="currentColor"
      >
        <path
          fill-rule="evenodd"
          d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z"
          clip-rule="evenodd"></path>
      </svg>
    </button>
    <HeaderSearch />
    <DateSelector
      dateIndex={dateIndex}
      baseUrl={`${base}blog`}
      currentYear={currentYear}
      currentMonth={currentMonth}
    />
  </div>

  <!-- Right: BMC + Theme chooser + Telegram -->
  <div class="header-actions">
    <a
      target="_blank"
      rel="noopener noreferrer"
      href="https://buymeacoffee.com/hellomraz"
      class="header-btn"
    >
      <span class="bmc-icon">☕</span>
      <span class="bmc-label">BUY ME A COFFEE</span>
    </a>
    <span class="header-sep">│</span>
    <ThemeChooser />
    <span class="header-sep">│</span>
    <LangSwitcher />
    <span class="header-sep">│</span>
    <a
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Telegram channel"
      href="https://t.me/hellomraz"
      class="header-icon-link"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path
          d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
        ></path>
      </svg>
    </a>
  </div>
</div>

<style>
  .page-header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid var(--theme-border);
    background-color: var(--theme-bg-surface);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }
  .header-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.75rem;
    min-height: 44px;
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid var(--theme-border);
    color: var(--theme-text-muted);
    background: var(--theme-bg-elevated);
    text-decoration: none;
    transition:
      border-color 0.15s,
      color 0.15s;
  }
  .header-btn:hover {
    border-color: var(--theme-accent);
    color: var(--theme-accent);
  }
  .header-sep {
    color: var(--theme-border);
  }
  .header-icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    color: var(--theme-text-muted);
    transition: color 0.15s;
  }
  .header-icon-link:hover {
    color: var(--theme-accent);
  }

  /* Mobile: stack date picker above actions */
  @media (max-width: 640px) {
    .page-header {
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
      padding: 0.5rem 0.75rem;
    }
    .header-left {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .header-actions {
      justify-content: flex-start;
      gap: 0.5rem;
    }
    .header-sep {
      display: none;
    }
    .bmc-label {
      display: none;
    }
  }
  /* Tablet and up: header-left inline */
  @media (min-width: 641px) {
    .header-left {
      flex: 1;
      min-width: 0;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
  }
  .mobile-menu-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    color: var(--theme-text-muted);
    background: var(--theme-bg-elevated);
    border: 1px solid var(--theme-border);
    cursor: pointer;
    transition:
      border-color 0.15s,
      color 0.15s;
  }
  .mobile-menu-btn:hover {
    border-color: var(--theme-accent);
    color: var(--theme-accent);
  }
  @media (min-width: 1024px) {
    .mobile-menu-btn {
      display: none;
    }
  }
</style>
