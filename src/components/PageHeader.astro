---
import ThemeChooser from "./ThemeChooser.astro";
import LangSwitcher from "./LangSwitcher.astro";
import DateSelector from "./DateSelector.astro";
import { getCollection } from "astro:content";

const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");

// Build date index for DateSelector — always available in the header
const pageSize = 24;
const allPosts = await getCollection("blog");
const sorted = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const dateIndex: Record<string, number> = {};
sorted.forEach((post, i) => {
  const d = post.data.pubDate;
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
  if (!(key in dateIndex)) {
    dateIndex[key] = Math.floor(i / pageSize) + 1;
  }
});
---

<div
  class="page-header"
  transition:name="page-header"
  transition:persist
>
  <!-- Left: Hamburger (mobile) + Date picker -->
  <div class="header-left">
    <button
      id="mobile-menu-btn"
      class="mobile-menu-btn"
      aria-label="Open menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd" />
      </svg>
    </button>
    <DateSelector dateIndex={dateIndex} baseUrl={`${base}blog`} />
  </div>

  <!-- Right: BMC + Theme chooser + Telegram -->
  <div class="header-actions">
    <a
      target="_blank"
      rel="noopener noreferrer"
      href="https://buymeacoffee.com/hellomraz"
      class="header-btn"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.216 6.415l-.132-.666c-.119-.598-.388-1.163-1.001-1.379-.197-.069-.42-.098-.57-.241-.152-.143-.196-.366-.231-.572-.065-.378-.125-.756-.192-1.133-.057-.325-.102-.69-.25-.987-.195-.4-.597-.634-.996-.788a5.723 5.723 0 00-.626-.194c-1-.263-2.05-.36-3.077-.416a25.834 25.834 0 00-3.7.062c-.915.083-1.88.184-2.75.5-.318.116-.646.256-.888.501-.297.302-.393.77-.177 1.146.154.267.415.456.692.58.36.162.737.284 1.123.366 1.075.238 2.189.331 3.287.37 1.218.05 2.437.01 3.65-.118.299-.033.598-.073.896-.119.352-.054.578-.513.474-.834-.124-.383-.457-.531-.834-.473-.466.074-.96.108-1.382.146-1.177.08-2.358.082-3.536.006a22.228 22.228 0 01-1.157-.107c-.086-.01-.18-.025-.258-.036-.243-.036-.484-.08-.724-.13-.111-.027-.111-.185 0-.212h.005c.277-.06.557-.108.838-.147h.002c.131-.009.263-.032.394-.048a25.076 25.076 0 013.426-.12c.674.019 1.347.062 2.014.13l.04.005c.427.047.853.1 1.28.157.107.014.218.033.325.048.105.014.39.077.39.077.093.019.266.023.326-.063.06-.085.063-.242.05-.366z"/>
        <path d="M7.5 12.5c0 .828-.448 1.5-1 1.5s-1-.672-1-1.5.448-1.5 1-1.5 1 .672 1 1.5z"/>
        <path d="M20.5 11H19V9.5C19 8.673 18.327 8 17.5 8h-11C5.673 8 5 8.673 5 9.5V11H3.5C2.673 11 2 11.673 2 12.5S2.673 14 3.5 14H5v.5c0 2.485 2.015 4.5 4.5 4.5h5c2.485 0 4.5-2.015 4.5-4.5V14h1.5c.827 0 1.5-.673 1.5-1.5s-.673-1.5-1.5-1.5zM17 14.5c0 1.381-1.119 2.5-2.5 2.5h-5C8.119 17 7 15.881 7 14.5v-5C7 9.224 7.224 9 7.5 9h9c.276 0 .5.224.5.5v5z"/>
      </svg>
      <span class="bmc-label">buy me a coffee</span>
    </a>
    <span class="header-sep">│</span>
    <ThemeChooser />
    <span class="header-sep">│</span>
    <LangSwitcher />
    <span class="header-sep">│</span>
    <a
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Telegram channel"
      href="https://t.me/hellomraz"
      class="header-icon-link"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path
          d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
        ></path>
      </svg>
    </a>
  </div>
</div>

<style>
  .page-header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid var(--theme-border);
    background-color: var(--theme-bg-surface);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }
  .header-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.75rem;
    min-height: 44px;
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid var(--theme-border);
    color: var(--theme-text-muted);
    background: var(--theme-bg-elevated);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .header-btn:hover {
    border-color: var(--theme-accent);
    color: var(--theme-accent);
  }
  .header-sep {
    color: var(--theme-border);
  }
  .header-icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    color: var(--theme-text-muted);
    transition: color 0.15s;
  }
  .header-icon-link:hover {
    color: var(--theme-accent);
  }

  /* Mobile: stack date picker above actions */
  @media (max-width: 640px) {
    .page-header {
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
      padding: 0.5rem 0.75rem;
    }
    .header-left {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .header-actions {
      justify-content: flex-start;
      gap: 0.5rem;
    }
    .header-sep {
      display: none;
    }
    .bmc-label {
      display: none;
    }
  }
  /* Tablet and up: header-left inline */
  @media (min-width: 641px) {
    .header-left {
      flex: 1;
      min-width: 0;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
  }
  .mobile-menu-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    color: var(--theme-text-muted);
    background: var(--theme-bg-elevated);
    border: 1px solid var(--theme-border);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .mobile-menu-btn:hover {
    border-color: var(--theme-accent);
    color: var(--theme-accent);
  }
  @media (min-width: 1024px) {
    .mobile-menu-btn {
      display: none;
    }
  }
</style>
