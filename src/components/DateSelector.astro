---
/**
 * DateSelector — cascading Year / Month picker that navigates to the
 * correct paginated page and scrolls to the month group anchor.
 * Also includes a themed tag picker with search + top tags.
 *
 * Props:
 *   dateIndex – JSON-serialisable map: { "2026-02": 1, "2026-01": 2, … }
 *   baseUrl   – e.g. "/blog"
 */

interface Props {
  dateIndex: Record<string, number>;
  baseUrl: string;
  currentYear?: number;
  currentMonth?: number;
}

const { dateIndex, baseUrl, currentYear, currentMonth } = Astro.props;

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');

// Derive available years and months-per-year
const yearMonths: Record<number, number[]> = {};
for (const key of Object.keys(dateIndex)) {
  const [y, m] = key.split('-').map(Number);
  if (!yearMonths[y]) yearMonths[y] = [];
  yearMonths[y].push(m);
}
const sortedYears = Object.keys(yearMonths)
  .map(Number)
  .sort((a, b) => b - a);
for (const y of sortedYears) {
  yearMonths[y].sort((a, b) => b - a);
}

const MONTH_NAMES = [
  '',
  'Jan',
  'Feb',
  'Mar',
  'Apr',
  'May',
  'Jun',
  'Jul',
  'Aug',
  'Sep',
  'Oct',
  'Nov',
  'Dec',
];
---

<div class="date-selector" data-base={base} data-current-month={currentMonth ?? ''}>
  <label class="ds-label">Jump to</label>

  <select class="ds-select" data-ds-year>
    <option value="">Year</option>
    {
      sortedYears.map((y) => (
        <option value={y} selected={y === currentYear}>
          {y}
        </option>
      ))
    }
  </select>

  <select class="ds-select" data-ds-month disabled>
    <option value="">Month</option>
  </select>

  <button class="ds-go-btn" type="button" data-ds-go disabled>Go</button>

  <span class="ds-sep">│</span>

  <div class="ds-tag-picker">
    <button
      class="header-control-btn"
      type="button"
      data-ds-tag-btn
      aria-expanded="false"
      aria-haspopup="listbox"
    >
      <span>#tag</span>
      <span class="header-control-arrow" data-ds-tag-arrow>▾</span>
    </button>
  </div>
</div>

<script define:vars={{ yearMonths, dateIndex, baseUrl, MONTH_NAMES }}>
  function navigateInternal(url) {
    const navigate = window.__hellomrazNavigate;

    if (typeof navigate === 'function') {
      void navigate(url);
      return;
    }

    window.location.assign(url);
  }

  function populateMonths(monthEl, goEl, year, selectedMonth = '') {
    monthEl.innerHTML = '<option value="">Month</option>';

    const yearKey = Number(year);
    if (!year || !yearMonths[yearKey]) {
      monthEl.disabled = true;
      goEl.disabled = true;
      return;
    }

    for (const month of yearMonths[yearKey]) {
      const option = document.createElement('option');
      option.value = String(month);
      option.textContent = MONTH_NAMES[month];
      option.selected = String(month) === selectedMonth;
      monthEl.appendChild(option);
    }

    monthEl.disabled = false;
    goEl.disabled = !monthEl.value;
  }

  function bindDateSelector(root) {
    if (root.dataset.dateSelectorBound === 'true') {
      return;
    }
    root.dataset.dateSelectorBound = 'true';

    const yearEl = root.querySelector('[data-ds-year]');
    const monthEl = root.querySelector('[data-ds-month]');
    const goEl = root.querySelector('[data-ds-go]');
    if (!yearEl || !monthEl || !goEl) {
      return;
    }

    const initialMonth = root.dataset.currentMonth || '';

    yearEl.addEventListener('change', () => {
      populateMonths(monthEl, goEl, yearEl.value);
    });

    monthEl.addEventListener('change', () => {
      goEl.disabled = !monthEl.value;
    });

    goEl.addEventListener('click', () => {
      const year = yearEl.value;
      const month = monthEl.value.padStart(2, '0');
      const key = `${year}-${month}`;
      const page = dateIndex[key];
      if (page == null) return;
      const url = page === 1 ? baseUrl : `${baseUrl}/${page}`;
      navigateInternal(`${url}#month-${key}`);
    });

    if (yearEl.value) {
      populateMonths(monthEl, goEl, yearEl.value, initialMonth);
    }
  }

  function initDateSelectors() {
    document.querySelectorAll('.date-selector').forEach(bindDateSelector);
  }

  if (!window.__dateSelectorPageLoadBound) {
    window.__dateSelectorPageLoadBound = true;
    document.addEventListener('astro:page-load', initDateSelectors);
  }
  initDateSelectors();
</script>

<script>
  import { createFloatingDropdown } from '../lib/floating-dropdown.mjs';

  interface TagSummary {
    name: string;
    count: number;
  }

  interface DateSelectorRoot extends HTMLElement {
    __tagPickerBound?: boolean;
    __tagDropdown?: HTMLElement | null;
  }

  type DateSelectorWindow = Window & {
    __dateSelectorTagPageLoadBound?: boolean;
  };

  const INITIAL_SHOW = 10;
  const tagDataCache = new Map<string, Promise<TagSummary[]>>();

  function navigateInternal(url: string) {
    const navigate = (window as Window & {
      __hellomrazNavigate?: (href: string) => Promise<void> | void;
    }).__hellomrazNavigate;

    if (typeof navigate === 'function') {
      void navigate(url);
      return;
    }

    window.location.assign(url);
  }

  function getBase(root: HTMLElement): string {
    return root.dataset.base || '/';
  }

  function loadTags(base: string) {
    let request = tagDataCache.get(base);
    if (!request) {
      request = fetch(`${base}api/tags.json`)
        .then(async (response) => {
          if (!response.ok) {
            throw new Error('Failed to load tags');
          }
          return (await response.json()) as TagSummary[];
        })
        .catch(() => [] as TagSummary[]);
      tagDataCache.set(base, request);
    }
    return request;
  }

  function ensureDropdown(
    root: DateSelectorRoot,
    tags: TagSummary[],
    closeDropdown: () => void,
  ) {
    if (root.__tagDropdown?.isConnected) {
      return root.__tagDropdown;
    }

    const dropdown = document.createElement('div');
    dropdown.className = 'ds-tag-dropdown';
    dropdown.hidden = true;

    const searchWrap = document.createElement('div');
    searchWrap.className = 'ds-tag-search-wrap';
    const searchInput = document.createElement('input');
    searchInput.type = 'text';
    searchInput.placeholder = 'search tags…';
    searchInput.className = 'ds-tag-search';
    searchInput.autocomplete = 'off';
    searchWrap.appendChild(searchInput);
    dropdown.appendChild(searchWrap);

    const listEl = document.createElement('div');
    listEl.className = 'ds-tag-list';
    dropdown.appendChild(listEl);

    const moreBtn = document.createElement('a');
    moreBtn.className = 'ds-tag-more';
    moreBtn.href = `${getBase(root)}tags/`;
    moreBtn.textContent = `all ${tags.length} tags →`;
    moreBtn.addEventListener('click', (event) => {
      event.preventDefault();
      closeDropdown();
      navigateInternal(moreBtn.href);
    });
    dropdown.appendChild(moreBtn);

    function renderTags(filter: string) {
      listEl.innerHTML = '';
      const query = filter.toLowerCase().trim();
      let items = tags;

      if (query) {
        items = tags.filter((tag) => tag.name.toLowerCase().includes(query));
        moreBtn.hidden = true;
      } else {
        items = tags.slice(0, INITIAL_SHOW);
        moreBtn.hidden = false;
      }

      if (items.length === 0) {
        const empty = document.createElement('div');
        empty.className = 'ds-tag-empty';
        empty.textContent = 'no matching tags';
        listEl.appendChild(empty);
        return;
      }

      for (const tag of items) {
        const link = document.createElement('a');
        link.href = `${getBase(root)}tags/${encodeURIComponent(tag.name)}`;
        link.className = 'ds-tag-item';

        const name = document.createElement('span');
        name.className = 'ds-tag-name';
        name.textContent = `#${tag.name}`;
        link.appendChild(name);

        const count = document.createElement('span');
        count.className = 'ds-tag-count';
        count.textContent = String(tag.count);
        link.appendChild(count);

        link.addEventListener('click', (event) => {
          event.preventDefault();
          closeDropdown();
          navigateInternal(link.href);
        });

        listEl.appendChild(link);
      }
    }

    searchInput.addEventListener('input', () => {
      renderTags(searchInput.value);
    });

    searchInput.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        const first = listEl.querySelector('.ds-tag-item') as HTMLAnchorElement | null;
        if (first) {
          closeDropdown();
          navigateInternal(first.href);
        }
      }
    });

    renderTags('');
    root.__tagDropdown = dropdown;
    return dropdown;
  }

  function bindTagPicker(root: DateSelectorRoot) {
    if (root.__tagPickerBound) {
      return;
    }
    root.__tagPickerBound = true;

    const button = root.querySelector<HTMLButtonElement>('[data-ds-tag-btn]');
    const arrow = root.querySelector<HTMLElement>('[data-ds-tag-arrow]');
    if (!button || !arrow) {
      return;
    }

    const floatingTagDropdown = createFloatingDropdown({
      getAnchor: () => button,
      getPanel: () => root.__tagDropdown ?? null,
      useOverlay: true,
      zIndex: 99999,
      position: {
        align: 'start',
        width: 280,
        offset: 4,
        viewportPadding: 4,
        maxHeight: 400,
      },
      onOpenChange(open, panel) {
        button.setAttribute('aria-expanded', open ? 'true' : 'false');
        arrow.classList.toggle('is-open', open);

        if (open && panel) {
          const input = panel.querySelector('.ds-tag-search') as HTMLInputElement | null;
          if (input) {
            input.value = '';
            input.dispatchEvent(new Event('input'));
            requestAnimationFrame(() => input.focus());
          }
        }
      },
    });

    button.addEventListener('click', async (event) => {
      event.stopPropagation();
      const tags = await loadTags(getBase(root));
      ensureDropdown(root, tags, () => floatingTagDropdown.close());
      floatingTagDropdown.toggle();
    });
  }

  function initTagPickers() {
    document
      .querySelectorAll<DateSelectorRoot>('.date-selector')
      .forEach(bindTagPicker);
  }

  if (!(window as DateSelectorWindow).__dateSelectorTagPageLoadBound) {
    (window as DateSelectorWindow).__dateSelectorTagPageLoadBound = true;
    document.addEventListener('astro:page-load', initTagPickers);
  }
  initTagPickers();
</script>

<style>
  .date-selector {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .ds-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--theme-text-muted);
  }
  .ds-select {
    font-size: 0.875rem;
    padding: 0.5rem 0.75rem;
    min-height: 44px;
    border: 1px solid var(--theme-border);
    border-radius: 0.375rem;
    background-color: var(--theme-bg-elevated);
    color: var(--theme-text-primary);
    outline: none;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .ds-select:hover {
    border-color: var(--theme-accent);
  }
  .ds-select:focus {
    border-color: var(--theme-accent);
    box-shadow: 0 0 0 2px
      color-mix(in srgb, var(--theme-accent) 25%, transparent);
  }
  .ds-go-btn {
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    min-height: 44px;
    border: none;
    border-radius: 0.375rem;
    background-color: var(--theme-accent);
    color: #fff;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .ds-go-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
  .ds-sep {
    color: var(--theme-border);
  }
  .ds-tag-picker {
    position: relative;
  }

  @media (max-width: 640px) {
    .ds-sep {
      display: none;
    }
  }
</style>

<style is:global>
  .ds-tag-dropdown {
    position: fixed;
    width: 280px;
    max-height: 400px;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--theme-border);
    border-radius: 0.5rem;
    background: var(--theme-bg-surface);
    z-index: 99999;
    opacity: 0;
    pointer-events: none;
    font-family: inherit;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    transition: opacity 0.1s;
  }
  .ds-tag-dropdown.is-open {
    opacity: 1;
    pointer-events: auto;
  }
  .ds-tag-search-wrap {
    padding: 0.5rem;
    border-bottom: 1px solid var(--theme-border);
    flex-shrink: 0;
  }
  .ds-tag-search {
    width: 100%;
    padding: 0.5rem 0.625rem;
    min-height: 36px;
    font-size: 0.8125rem;
    font-family: inherit;
    border: 1px solid var(--theme-border);
    border-radius: 0.375rem;
    background: var(--theme-bg-elevated);
    color: var(--theme-text-primary);
    outline: none;
    transition: border-color 0.15s;
    box-sizing: border-box;
  }
  .ds-tag-search::placeholder {
    color: var(--theme-text-muted);
  }
  .ds-tag-search:focus {
    border-color: var(--theme-accent);
    box-shadow: 0 0 0 2px
      color-mix(in srgb, var(--theme-accent) 25%, transparent);
  }
  .ds-tag-list {
    overflow-y: auto;
    flex: 1;
    min-height: 0;
    padding: 0.25rem 0;
  }
  .ds-tag-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
    min-height: 40px;
    text-decoration: none;
    color: var(--theme-text-secondary);
    cursor: pointer;
    transition:
      background 0.1s,
      color 0.1s;
  }
  .ds-tag-item:hover {
    background: var(--theme-bg-hover);
    color: var(--theme-text-primary);
  }
  .ds-tag-name {
    font-size: 0.8125rem;
    font-weight: 500;
  }
  .ds-tag-count {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    background: var(--theme-bg-elevated);
    color: var(--theme-text-muted);
    font-variant-numeric: tabular-nums;
  }
  .ds-tag-more {
    flex-shrink: 0;
    display: block;
    width: 100%;
    padding: 0.5rem 0.75rem;
    min-height: 40px;
    font-size: 0.75rem;
    font-family: inherit;
    font-weight: 500;
    text-align: center;
    border: none;
    border-top: 1px solid var(--theme-border);
    background: var(--theme-bg-surface);
    color: var(--theme-accent);
    cursor: pointer;
    transition: background 0.1s;
  }
  .ds-tag-more:hover {
    background: var(--theme-bg-hover);
  }
  .ds-tag-empty {
    padding: 1rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--theme-text-muted);
    text-align: center;
  }
</style>
