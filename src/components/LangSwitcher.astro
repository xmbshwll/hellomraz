<div id="lang-chooser">
  <button
    id="lang-chooser-btn"
    class="header-control-btn"
    aria-label="Choose language"
    aria-expanded="false"
    aria-haspopup="listbox"
  >
    <span id="lang-chooser-label">lang:ru</span>
    <span id="lang-chooser-arrow" class="header-control-arrow">▾</span>
  </button>
</div>

<style is:global>
  .lang-fallback-banner {
    padding: 8px 12px;
    margin-bottom: 12px;
    font-size: 12px;
    border: 1px dashed var(--theme-border);
    color: var(--theme-text-muted);
  }

  .markdown-content.is-translating {
    opacity: 0.5;
  }
</style>

<script>
  import { mountSelectableDropdown } from '../lib/selectable-dropdown.mjs';
  import {
    getCurrentSiteLang,
    setCurrentSiteLang,
    SITE_LANGS,
  } from '../lib/site-i18n.mjs';
  import { applyTranslationToElement, setupTranslationListener } from '../lib/translation.mjs';

  function getSlug(): string | null {
    return document.querySelector('[data-post-slug]')?.getAttribute('data-post-slug') || null;
  }

  function initLangSwitcher() {
    const lang = getCurrentSiteLang();
    if (lang !== 'ru') {
      const content = document.querySelector('.markdown-content');
      const slug = getSlug();
      if (content && slug) applyTranslationToElement(content, slug);
    }
  }

  mountSelectableDropdown({
    readyFlag: '__langChooserReady',
    buttonId: 'lang-chooser-btn',
    labelId: 'lang-chooser-label',
    arrowId: 'lang-chooser-arrow',
    panelId: 'lang-dropdown-portal',
    width: 200,
    align: 'end',
    useOverlay: true,
    maxHeight: 220,
    getOptions: () => SITE_LANGS,
    getCurrent: getCurrentSiteLang,
    setCurrent: (lang) => {
      setCurrentSiteLang(lang);
      const content = document.querySelector('.markdown-content');
      const slug = getSlug();
      if (content && slug) applyTranslationToElement(content, slug);
    },
    formatLabel: (lang) => `lang:${lang}`,
  });

  setupTranslationListener(getSlug);
  document.addEventListener('astro:page-load', initLangSwitcher);
  initLangSwitcher();
</script>
