---
interface Props {
  currentPage: number;
  lastPage: number;
  baseUrl: string; // e.g. "/blog"
}

const { currentPage, lastPage, baseUrl } = Astro.props;

// Build page URL — page 1 has no suffix
function pageUrl(page: number) {
  return page === 1 ? baseUrl : `${baseUrl}/${page}`;
}

// Determine which page numbers to show
function getPageNumbers(): (number | '...')[] {
  const pages: (number | '...')[] = [];
  if (lastPage <= 7) {
    for (let i = 1; i <= lastPage; i++) pages.push(i);
    return pages;
  }
  // Always show first, last, and a window around current
  const windowStart = Math.max(2, currentPage - 1);
  const windowEnd = Math.min(lastPage - 1, currentPage + 1);

  pages.push(1);
  if (windowStart > 2) pages.push('...');
  for (let i = windowStart; i <= windowEnd; i++) pages.push(i);
  if (windowEnd < lastPage - 1) pages.push('...');
  pages.push(lastPage);
  return pages;
}

const pageNumbers = getPageNumbers();
const hasPrev = currentPage > 1;
const hasNext = currentPage < lastPage;
---

<nav class="pagination" aria-label="Pagination">
  <!-- Previous -->
  {hasPrev ? (
    <a
      href={pageUrl(currentPage - 1)}
      class="pagination-link"
      aria-label="Previous page"
    >
      ← Prev
    </a>
  ) : (
    <span class="pagination-link pagination-link--disabled">
      ← Prev
    </span>
  )}

  <!-- Page numbers -->
  {pageNumbers.map((p) =>
    p === '...' ? (
      <span class="pagination-ellipsis">…</span>
    ) : p === currentPage ? (
      <span class="pagination-current" aria-current="page">
        {p}
      </span>
    ) : (
      <a href={pageUrl(p)} class="pagination-link">
        {p}
      </a>
    )
  )}

  <!-- Next -->
  {hasNext ? (
    <a
      href={pageUrl(currentPage + 1)}
      class="pagination-link"
      aria-label="Next page"
    >
      Next →
    </a>
  ) : (
    <span class="pagination-link pagination-link--disabled">
      Next →
    </span>
  )}
</nav>

<style>
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin: 2.5rem 0 1rem;
  }

  .pagination-link,
  .pagination-current,
  .pagination-ellipsis {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
  }

  .pagination-link {
    color: var(--theme-text-secondary);
    background-color: var(--theme-bg-elevated);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .pagination-link:hover {
    opacity: 0.8;
  }

  .pagination-link--disabled {
    color: var(--theme-text-muted);
    opacity: 0.4;
    cursor: not-allowed;
  }

  .pagination-current {
    color: #fff;
    background-color: var(--theme-accent);
    font-weight: 700;
  }

  .pagination-ellipsis {
    color: var(--theme-text-muted);
  }
</style>
