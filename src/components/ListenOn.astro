---
import type { StreamingLink } from '../lib/streaming';

interface Props {
  links: StreamingLink[];
}

const { links } = Astro.props;

const SERVICE_TONE_CLASSES: Record<string, string> = {
  Bandcamp: 'service-btn--bandcamp',
  Spotify: 'service-btn--spotify',
  'Apple Music': 'service-btn--apple-music',
  Tidal: 'service-btn--tidal',
  Deezer: 'service-btn--deezer',
  YouTube: 'service-btn--youtube',
  'YouTube Music': 'service-btn--youtube-music',
  SoundCloud: 'service-btn--soundcloud',
  'Yandex Music': 'service-btn--yandex-music',
};

function getToneClass(service: string): string {
  return SERVICE_TONE_CLASSES[service] ?? 'service-btn--default';
}

if (!links.length) return;
---

<div class="listen-on">
  <h3 class="section-heading">Listen on</h3>

  <div class="service-list">
    {
      links.map(({ service, url, icon }) => (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class:list={['service-btn', getToneClass(service)]}
        >
          <span class="service-icon">{icon}</span>
          {service}
        </a>
      ))
    }
  </div>
</div>

<style>
  .listen-on {
    border-top: 1px solid color-mix(in srgb, var(--theme-text-muted) 20%, transparent);
    padding-top: 20px;
    margin-top: 24px;
  }

  .section-heading {
    color: var(--theme-accent);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 14px;
    font-weight: 600;
  }

  .service-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .service-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: var(--theme-bg-hover);
    padding: 10px 14px;
    min-height: 44px;
    border-radius: 8px;
    text-decoration: none;
    font-size: 13px;
    color: var(--theme-text-primary);
    transition: background-color 0.2s, transform 0.15s;
  }

  .service-btn:hover {
    background-color: var(--theme-bg-elevated);
    transform: translateY(-1px);
  }

  .service-btn--bandcamp {
    color: var(--theme-accent);
  }

  .service-btn--spotify {
    color: #1db954;
  }

  .service-btn--apple-music {
    color: #fc3c44;
  }

  .service-btn--tidal {
    color: #00ffff;
  }

  .service-btn--deezer {
    color: #a238ff;
  }

  .service-btn--youtube,
  .service-btn--youtube-music {
    color: #ff0000;
  }

  .service-btn--soundcloud {
    color: #ff5500;
  }

  .service-btn--yandex-music {
    color: #ffcc00;
  }

  .service-icon {
    font-size: 15px;
  }
</style>
