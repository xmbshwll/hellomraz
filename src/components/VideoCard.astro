---
import { getVideoThumb } from '../lib/videos';

interface Props {
  title: string;
  youtubeId: string;
  tags?: string[];
  index?: number;
}

const { title, youtubeId, tags = [], index = 99 } = Astro.props;
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const thumbUrl = getVideoThumb(youtubeId);
const safeTitle = title.replace(/&/g, '&amp;').replace(/</g, '&lt;');
---

<a href={`${base}videos/${youtubeId}`} class="post-card video-item" data-youtube-id={youtubeId}>
  <div class="post-card-cover">
    <img src={thumbUrl} alt={safeTitle} width="300" height="300"
         class="post-card-img" loading={index < 8 ? 'eager' : 'lazy'} decoding="async">
    <div class="play-overlay" aria-hidden="true">&#9654;</div>
  </div>
  <div class="post-card-title">{safeTitle}</div>
  {tags.length > 0 && (
    <div class="post-card-tags">{tags.slice(0, 3).join(' \u00b7 ')}</div>
  )}
</a>

<style>
  .video-item {
    position: relative;
  }
  .play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.3);
    color: #fff;
    font-size: 2rem;
    opacity: 0;
    transition: opacity 0.15s;
    pointer-events: none;
  }
  .video-item:hover .play-overlay {
    opacity: 1;
  }
</style>
