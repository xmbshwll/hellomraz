---
import type { CollectionEntry } from 'astro:content';
import SideMenuItem from './SideMenuItem.astro';
import SideItemCard from './SideItemCard.astro';

interface Props {
  initialPosts: CollectionEntry<'blog'>[];
  hasMore: boolean;
}

const { initialPosts, hasMore } = Astro.props;
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const INITIAL_COUNT = initialPosts.length;
---

<div
  class="side-menu flex flex-col flex-1 h-full"
  data-side-menu
  data-base={base}
  data-initial-count={INITIAL_COUNT}
  data-rendered={INITIAL_COUNT}
  style="background-color: var(--theme-bg-base);"
>
  <!-- Nav links -->
  <div
    class="flex-shrink-0 border-b"
    style="border-color: var(--theme-border);"
  >
    <ul class="py-1">
      <SideMenuItem href={base} icon="home">ОПУСТИ ОРУЖИЕ, МРАЗЬ</SideMenuItem>
    </ul>
  </div>

  <!-- About blurb -->
  <div
    class="flex-shrink-0 border-b px-4 py-3"
    style="border-color: var(--theme-border);"
  >
    <h2
      class="text-xs font-bold uppercase tracking-widest mb-2"
      style="color: var(--theme-text-muted);"
    >
      ~ about
    </h2>
    <p
      class="text-xs leading-relaxed"
      style="color: var(--theme-text-secondary);"
      data-sidebar-about-text
    >
      Лучшее музыкально-критическое СМИ в этой вселенной (возможно, после The
      Quietus).
    </p>
    <a
      href={`${base}about`}
      class="sidebar-about-link"
      data-sidebar-about-link
    >
      подробнее →
    </a>
  </div>

  <!-- Recent posts -->
  <div class="flex-1 overflow-y-auto min-h-0">
    <div
      class="sticky top-0 px-4 pt-3 pb-2 z-10 border-b"
      style="background-color: var(--theme-bg-base); border-color: var(--theme-border);"
    >
      <h2
        class="text-xs font-bold uppercase tracking-widest"
        style="color: var(--theme-text-muted);"
      >
        ~ recent
      </h2>
    </div>
    <ul class="pb-3" data-side-menu-list>
      {
        initialPosts.map((post) => (
          <li>
            <SideItemCard post={post} />
          </li>
        ))
      }
    </ul>
    {
      hasMore && (
        <div class="px-4 pb-3" data-side-menu-load-more-wrap>
          <button
            class="load-more-btn"
            type="button"
            data-side-menu-load-more-btn
          >
            Load more
          </button>
        </div>
      )
    }
  </div>
</div>

<style>
  .sidebar-about-link {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: var(--theme-accent);
    text-decoration: none;
    transition: text-decoration 0.15s;
  }
  .sidebar-about-link:hover {
    text-decoration: underline;
  }
  .load-more-btn {
    width: 100%;
    padding: 0.625rem;
    min-height: 44px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    color: var(--theme-text-muted);
    background-color: var(--theme-bg-hover);
    border: 1px solid var(--theme-border);
    border-radius: 0.25rem;
    transition: color 0.15s;
  }
  .load-more-btn:hover {
    color: var(--theme-text-primary);
  }
</style>

<script>
  import {
    getCurrentSiteLang,
    getSiteCopy,
  } from '../../lib/site-i18n.mjs';

  interface SidebarPost {
    slug: string;
    title: string;
    year: number;
  }

  let allPosts: SidebarPost[] | null = null;
  let loadPromise: Promise<SidebarPost[]> | null = null;
  let loaded = 0;
  let isLoadingMore = false;

  const boundRoots = new WeakSet<HTMLElement>();
  const BATCH = 12;

  function getRoots(): HTMLElement[] {
    return Array.from(
      document.querySelectorAll<HTMLElement>('[data-side-menu]'),
    );
  }

  function getInitialCount(root: HTMLElement): number {
    return Number(root.dataset.initialCount || '0');
  }

  function getBase(root: HTMLElement): string {
    return root.dataset.base || '/';
  }

  function escapeHtml(value: string): string {
    return value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function renderPost(post: SidebarPost, baseUrl: string): string {
    return `<li><a href="${baseUrl}blog/${escapeHtml(post.slug)}"
      class="side-item-card-dynamic"
    ><div class="side-item-info-dynamic">
        <div class="side-item-title-dynamic">${escapeHtml(post.title)}</div>
        <div class="side-item-year-dynamic">${post.year}</div>
      </div></a></li>`;
  }

  function setRenderedCount(root: HTMLElement, count: number) {
    root.dataset.rendered = String(count);
  }

  function getRenderedCount(root: HTMLElement): number {
    return Number(root.dataset.rendered || '0');
  }

  function appendPosts(root: HTMLElement, posts: SidebarPost[]) {
    if (!posts.length) return;

    const list = root.querySelector<HTMLElement>('[data-side-menu-list]');
    if (!list) return;

    const html = posts.map((post) => renderPost(post, getBase(root))).join('');
    list.insertAdjacentHTML('beforeend', html);
    setRenderedCount(root, getRenderedCount(root) + posts.length);
  }

  function hydrateLoadedPosts(root: HTMLElement) {
    if (!allPosts) return;

    const renderedExtra = Math.max(0, getRenderedCount(root) - getInitialCount(root));
    if (loaded <= renderedExtra) return;

    appendPosts(root, allPosts.slice(renderedExtra, loaded));
  }

  function setButtonText(text: string) {
    for (const root of getRoots()) {
      const button = root.querySelector<HTMLButtonElement>(
        '[data-side-menu-load-more-btn]',
      );
      if (button) button.textContent = text;
    }
  }

  function syncLoadMoreVisibility() {
    if (!allPosts) return;

    for (const root of getRoots()) {
      const wrap = root.querySelector<HTMLElement>('[data-side-menu-load-more-wrap]');
      const button = root.querySelector<HTMLButtonElement>(
        '[data-side-menu-load-more-btn]',
      );

      if (wrap) {
        wrap.style.display = loaded >= allPosts.length ? 'none' : '';
      }
      if (button && loaded < allPosts.length && !isLoadingMore) {
        button.textContent = 'Load more';
      }
    }
  }

  async function ensureAllPosts(baseUrl: string): Promise<SidebarPost[]> {
    if (allPosts) return allPosts;

    if (!loadPromise) {
      loadPromise = fetch(`${baseUrl}api/sidebar-posts.json`)
        .then(async (response) => {
          if (!response.ok) {
            throw new Error('Failed to load recent posts');
          }
          const posts = (await response.json()) as SidebarPost[];
          allPosts = posts;
          return posts;
        })
        .finally(() => {
          loadPromise = null;
        });
    }

    return loadPromise;
  }

  async function loadMore(root: HTMLElement) {
    if (isLoadingMore) return;

    isLoadingMore = true;
    setButtonText('Loading…');

    try {
      const posts = await ensureAllPosts(getBase(root));
      const nextBatch = posts.slice(loaded, loaded + BATCH);

      for (const sideMenuRoot of getRoots()) {
        appendPosts(sideMenuRoot, nextBatch);
      }

      loaded += nextBatch.length;
      syncLoadMoreVisibility();
    } catch {
      setButtonText('Failed to load');
    } finally {
      isLoadingMore = false;
      syncLoadMoreVisibility();
    }
  }

  function updateAboutBlurb() {
    const copy = getSiteCopy('sidebarAbout', getCurrentSiteLang());

    for (const root of getRoots()) {
      const text = root.querySelector<HTMLElement>('[data-sidebar-about-text]');
      const link = root.querySelector<HTMLElement>('[data-sidebar-about-link]');

      if (text) text.textContent = copy.text;
      if (link) link.textContent = copy.link;
    }
  }

  function bindSideMenu(root: HTMLElement) {
    if (boundRoots.has(root)) return;
    boundRoots.add(root);

    const button = root.querySelector<HTMLButtonElement>('[data-side-menu-load-more-btn]');
    if (button) {
      button.addEventListener('click', () => {
        void loadMore(root);
      });
    }

    hydrateLoadedPosts(root);
  }

  function initSideMenus() {
    getRoots().forEach(bindSideMenu);
    updateAboutBlurb();
    syncLoadMoreVisibility();
  }

  document.addEventListener('astro:page-load', initSideMenus);
  window.addEventListener('lang-changed', updateAboutBlurb);
  initSideMenus();
</script>

<style is:global>
  /* Dynamic sidebar cards injected by JS load-more */
  .side-item-card-dynamic {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    border-left: 2px solid transparent;
    color: var(--theme-text-muted);
    text-decoration: none;
    transition: color 0.15s, background-color 0.15s, border-left-color 0.15s;
  }
  .side-item-card-dynamic:hover {
    color: var(--theme-text-primary);
    background-color: var(--theme-bg-hover);
    border-left-color: var(--theme-accent);
  }
  .side-item-info-dynamic {
    flex: 1;
    min-width: 0;
  }
  .side-item-title-dynamic {
    font-size: 0.875rem;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: inherit;
  }
  .side-item-year-dynamic {
    font-size: 0.75rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--theme-text-muted);
  }
</style>
