<div id="theme-chooser">
  <button
    id="theme-chooser-btn"
    class="header-control-btn"
    aria-label="Choose theme"
    aria-expanded="false"
    aria-haspopup="listbox"
  >
    <span id="theme-chooser-label">theme:dark</span>
    <span id="theme-chooser-arrow" class="header-control-arrow">▾</span>
  </button>
</div>

<script>
  import { mountSelectableDropdown } from '../lib/selectable-dropdown.mjs';

  const themes = [
    { id: 'dark', label: 'dark', bg: '#2E3440', accent: '#88C0D0' },
    { id: 'light', label: 'light', bg: '#ECEFF4', accent: '#5E81AC' },
    { id: 'divider-1', divider: true },
    { id: 'nord', label: 'nord', bg: '#2E3440', accent: '#88C0D0' },
    { id: 'nord-light', label: 'nord-light', bg: '#ECEFF4', accent: '#5E81AC' },
    { id: 'divider-2', divider: true },
    { id: 'catppuccin-mocha', label: 'catppuccin-mocha', bg: '#1e1e2e', accent: '#89b4fa' },
    { id: 'catppuccin-macchiato', label: 'catppuccin-macchiato', bg: '#24273a', accent: '#8aadf4' },
    { id: 'catppuccin-frappe', label: 'catppuccin-frappé', bg: '#303446', accent: '#8caaee' },
    { id: 'catppuccin-latte', label: 'catppuccin-latte', bg: '#eff1f5', accent: '#1e66f5' },
    { id: 'divider-3', divider: true },
    { id: 'rose-pine', label: 'rose-pine', bg: '#191724', accent: '#31748f' },
    { id: 'rose-pine-moon', label: 'rose-pine-moon', bg: '#232136', accent: '#3e8fb0' },
    { id: 'rose-pine-dawn', label: 'rose-pine-dawn', bg: '#faf4ed', accent: '#286983' },
  ];

  const lightThemes = new Set([
    'light',
    'nord-light',
    'catppuccin-latte',
    'rose-pine-dawn',
  ]);

  function isLightTheme(theme: string): boolean {
    return lightThemes.has(theme);
  }

  function setColorTheme(theme: string) {
    const html = document.documentElement;
    const mode = isLightTheme(theme) ? 'light' : 'dark';

    html.setAttribute('data-theme', theme);
    html.classList.toggle('dark', mode === 'dark');

    localStorage.setItem('color-theme', theme);
    localStorage.setItem('theme', mode);
  }

  function renderThemeSwatch(theme: {
    id: string;
    bg?: string;
    accent?: string;
    divider?: boolean;
  }): Node | null {
    if (theme.divider) return null;

    const swatch = document.createElement('span');
    swatch.className = 'chooser-swatch';
    swatch.style.setProperty('--chooser-swatch-bg', theme.bg ?? 'transparent');
    swatch.style.setProperty(
      '--chooser-swatch-accent',
      theme.accent ?? 'transparent',
    );

    swatch.append(
      Object.assign(document.createElement('span'), {
        className: 'chooser-swatch-half',
      }),
      Object.assign(document.createElement('span'), {
        className: 'chooser-swatch-half',
      }),
    );

    return swatch;
  }

  mountSelectableDropdown({
    readyFlag: '__themeChooserReady',
    buttonId: 'theme-chooser-btn',
    labelId: 'theme-chooser-label',
    arrowId: 'theme-chooser-arrow',
    panelId: 'theme-dropdown-portal',
    width: 240,
    align: 'end',
    useOverlay: true,
    maxHeight: 720,
    getOptions: () => themes,
    getCurrent: () => localStorage.getItem('color-theme') || 'dark',
    setCurrent: setColorTheme,
    formatLabel: (theme) => `theme:${theme}`,
    renderOptionLead: renderThemeSwatch,
  });
</script>
